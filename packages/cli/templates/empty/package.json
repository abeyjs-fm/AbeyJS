{
  "name": "abeyjs-starter",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:clean": "node scripts/clean-vite.mjs && vite",
    "dev:qa": "vite --mode qa",
    "build": "tsc -p tsconfig.json && vite build",
    "build:qa": "tsc -p tsconfig.json && vite build --mode qa",
    "preview": "vite preview",
    "abeyjs:connect": "abeyjs connect",
    "abeyjs:connect:insecure": "abeyjs connect --insecure",
    "abeyjs:generate:views": "abeyjs generate views"
  },
  "dependencies": {
    "@abeyjs/agents": "^0.1.2",
    "@abeyjs/core": "^0.1.1",
    "@abeyjs/http": "^0.1.1",
    "@abeyjs/inspector": "^0.1.2",
    "@abeyjs/runtime": "^0.1.4",
    "@abeyjs/uikit": "^0.1.6",
    "@abeyjs/view": "^0.1.8",
    "@abeyjs/flows": "^0.1.1"
  },
  "devDependencies": {
    "@abeyjs/cli": "^0.1.15",
    "@abeyjs/compiler": "^0.1.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
