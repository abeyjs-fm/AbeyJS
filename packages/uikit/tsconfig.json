{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "experimentalDecorators": true,
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@abeyjs/view/dom/define-abey-component": [
        "../view/dist/dom/define-abey-component.d.ts"
      ]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "dist/**/*", "node_modules"]
}
