{
  "name": "@abeyjs/view",
  "version": "0.1.6",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dev/vite-logger": {
      "types": "./dist/dev/abey-vite-logger.d.ts",
      "import": "./dist/dev/abey-vite-logger.js"
    },
    "./dev/vite-malformed-uri-guard": {
      "types": "./dist/dev/vite-malformed-uri-guard.d.ts",
      "import": "./dist/dev/vite-malformed-uri-guard.js"
    },
    "./dev/vite-docs-static-site": {
      "types": "./dist/dev/vite-docs-static-site.d.ts",
      "import": "./dist/dev/vite-docs-static-site.js"
    },
    "./dev/sync-spa-html-fallback-paths": {
      "types": "./dist/dev/sync-spa-html-fallback-paths.d.ts",
      "import": "./dist/dev/sync-spa-html-fallback-paths.js"
    },
    "./dev/spa-fallback-paths-ast": {
      "types": "./dist/dev/spa-fallback-paths-ast.d.ts",
      "import": "./dist/dev/spa-fallback-paths-ast.js"
    },
    "./dom/define-abey-component": {
      "types": "./dist/dom/define-abey-component.d.ts",
      "import": "./dist/dom/define-abey-component.js"
    },
    "./form/entity-form-values": {
      "types": "./src/form/entity-form-values.ts",
      "import": "./src/form/entity-form-values.ts"
    },
    "./theme/*": "./theme/*"
  },
  "bin": {
    "abey-sync-spa-paths": "./bin/abey-sync-spa-paths.js"
  },
  "files": [
    "bin",
    "dist",
    "theme"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "zod": "^3.24.0"
  },
  "dependencies": {
    "@abeyjs/core": "0.1.1",
    "@abeyjs/runtime": "^0.1.3",
    "@abeyjs/state": "0.1.1",
    "@abeyjs/uikit": "0.1.5",
    "@abeyjs/validation": "0.1.1",
    "typescript": "^5.7.0"
  }
}
