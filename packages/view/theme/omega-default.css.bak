body {
  margin: 0;
  min-height: 100%;
}


:root {
  /* Tipograf├¡a */
  --abey-font-sans: ui-sans-serif, system-ui, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  --abey-font-mono: ui-monospace, "Cascadia Code", "SFMono-Regular", Menlo, Consolas, monospace;
}

/* --- Claro (por defecto) bajo .abey --- */
.abey {
  /* Superficies */
  --abey-bg: #f6f7f9;
  --abey-surface: #ffffff;
  --abey-surface-elev: #fcfcfd;
  --abey-border: #e1e4e8;
  --abey-border-strong: #c9ced6;
  /* Texto */
  --abey-text: #1a1d21;
  --abey-text-muted: #5c636d;
  --abey-on-accent: #ffffff;
  /* Acento / interacci├│n */
  --abey-accent: #2563eb;
  --abey-accent-hover: #1d4ed8;
  --abey-focus: rgba(37, 99, 235, 0.35);
  /* Estado */
  --abey-error: #dc2626;
  --abey-error-bg: #fef2f2;
  /* Radio / sombra */
  --abey-radius: 10px;
  --abey-radius-sm: 6px;
  --abey-shadow: 0 1px 2px rgba(15, 23, 42, 0.06), 0 0 0 1px var(--abey-border);
  --abey-shadow-lg: 0 10px 30px -12px rgba(15, 23, 42, 0.18);
  /* App shell (sidebar / appbar) */
  --abey-appbar-h: 3.5rem;
  --abey-sidebar-w: 15.5rem;
  /* Espaciado */
  --abey-space-1: 0.25rem;
  --abey-space-2: 0.5rem;
  --abey-space-3: 0.75rem;
  --abey-space-4: 1rem;
  --abey-space-5: 1.25rem;
  --abey-space-6: 1.5rem;

  box-sizing: border-box;
  color: var(--abey-text);
  font-family: var(--abey-font-sans);
  font-size: 15px;
  line-height: 1.5;
  /* Native checkbox / radio / select track OS dark UI with `accent-color` + `--abey-*` (inherited into Shadow DOM). */
  color-scheme: light;
}

.abey *,
.abey *::before,
.abey *::after {
  box-sizing: border-box;
}

.abey.abey--dark {
  --abey-bg: #0b0f14;
  --abey-surface: #111827;
  --abey-surface-elev: #151b2a;
  --abey-border: #243045;
  --abey-border-strong: #3d4a5f;
  --abey-text: #e8eaed;
  --abey-text-muted: #9aa3b2;
  --abey-on-accent: #f8fafc;
  --abey-accent: #38bdf8;
  --abey-accent-hover: #0ea5e9;
  --abey-focus: rgba(56, 189, 248, 0.35);
  --abey-error: #f87171;
  --abey-error-bg: rgba(127, 29, 29, 0.35);
  --abey-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  --abey-shadow-lg: 0 12px 32px -10px rgba(0, 0, 0, 0.55);
  color-scheme: dark;
}

.abey-app {
  min-height: 100vh;
  margin: 0;
  background: var(--abey-bg);
  color: var(--abey-text);
  font-family: var(--abey-font-sans);
  font-size: 15px;
  line-height: 1.55;
  --abey-text: #1a1d21;
  --abey-text-muted: #5c636d;
  --abey-accent: #2563eb;
  --abey-radius: 10px;
  --abey-surface: #ffffff;
  --abey-border: #e1e4e8;
  --abey-radius-sm: 6px;
}

.abey-app:not(.abey-shell-app)>* {
  max-width: 960px;
  margin-left: auto;
  margin-right: auto;
  padding-left: var(--abey-space-4);
  padding-right: var(--abey-space-4);
  padding-top: var(--abey-space-2);
  padding-bottom: var(--abey-space-2);
}

.abey-app h1 {
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  margin: 0 0 var(--abey-space-2);
  color: var(--abey-text);
}

.abey-app p {
  color: var(--abey-text-muted);
  margin: 0 0 var(--abey-space-3);
  font-size: 0.95rem;
}

.abey-hero {
  margin-bottom: var(--abey-space-4);
}

.abey-toolbar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--abey-space-2);
  margin: var(--abey-space-4) 0;
  padding: var(--abey-space-3) var(--abey-space-4);
  background: var(--abey-surface, #fff);
  border: 1px solid var(--abey-border, #e1e4e8);
  border-radius: var(--abey-radius, 10px);
  box-shadow: var(--abey-shadow, none);
}

.abey-app>hr,
.abey hr,
hr.abey-divider {
  border: none;
  height: 1px;
  background: var(--abey-border, #e1e4e8);
  margin: var(--abey-space-4) 0;
  max-width: 960px;
  margin-left: auto;
  margin-right: auto;
  padding: 0 var(--abey-space-4);
  background-clip: content-box;
}

.abey-list,
.abey-form,
.abey-trace {
  display: block;
  margin: var(--abey-space-4) 0;
  padding: var(--abey-space-5) var(--abey-space-5);
  background: var(--abey-surface);
  border: 1px solid var(--abey-border);
  border-radius: var(--abey-radius);
  box-shadow: var(--abey-shadow);
  max-width: 960px;
  margin-left: auto;
  margin-right: auto;
}

.abey-form.abey-form--full {
  max-width: none !important;
  width: 100% !important;
  margin-left: 0 !important;
  margin-right: 0 !important;
}

abey-form.abey-form:has(.abey-form.abey-form--full) {
  max-width: none !important;
  width: 100% !important;
  margin-left: 0 !important;
  margin-right: 0 !important;
}

abey-form.abey-form>section.abey-form {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

.abey-openapi-crud {
  --abey-crud-max-w: 1180px;
}

.abey-openapi-crud .abey-toolbar,
.abey-openapi-crud .abey-list,
.abey-openapi-crud .abey-form,
.abey-openapi-crud .abey-trace {
  width: 100%;
  max-width: var(--abey-crud-max-w);
  margin-left: auto;
  margin-right: auto;
}

.abey-list {
  padding: 0;
  overflow: hidden;
}

.abey-list__title,
.abey-form__title,
.abey-trace__head {
  font-size: 1.05rem;
  font-weight: 600;
  margin: 0;
  padding: var(--abey-space-4) var(--abey-space-5);
  color: var(--abey-text);
  border-bottom: 1px solid var(--abey-border);
  background: var(--abey-surface-elev);
}

.abey-trace {
  box-shadow: var(--abey-shadow);
}

.abey-trace__head {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--abey-space-2);
  padding: var(--abey-space-3) var(--abey-space-4);
}

.abey-trace__list {
  list-style: none;
  margin: 0;
  padding: var(--abey-space-3) var(--abey-space-4);
  font-family: var(--abey-font-mono);
  font-size: 12.5px;
  line-height: 1.45;
  color: var(--abey-text-muted);
  max-height: 18rem;
  overflow: auto;
  background: var(--abey-bg, #f6f7f9);
}

.abey-trace__item {
  margin-bottom: var(--abey-space-2);
  word-break: break-word;
}

.abey-trace__code {
  white-space: pre-wrap;
  color: var(--abey-text);
  font-size: 12px;
}

.abey-list__table-wrap {
  padding: 0;
  overflow-x: auto;
}

.abey-list__table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  font-size: 0.9rem;
}

@media (max-width: 1024px) {
  .abey-list__table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .abey-list__table {
    min-width: 640px;
  }
}

@media (max-width: 640px) {
  .abey-list__table {
    min-width: 560px;
  }
}

.abey-list__table thead th {
  text-align: left;
  font-weight: 600;
  color: var(--abey-text-muted);
  text-transform: uppercase;
  font-size: 0.7rem;
  letter-spacing: 0.04em;
  padding: var(--abey-space-2) var(--abey-space-3);
  border-bottom: 1px solid var(--abey-border);
  background: var(--abey-surface-elev);
  white-space: nowrap;
}

.abey-list__table td {
  padding: var(--abey-space-3) var(--abey-space-3);
  border-bottom: 1px solid var(--abey-border);
  color: var(--abey-text);
  vertical-align: middle;
}

.abey-list__table tbody tr:hover td {
  background: rgba(37, 99, 235, 0.04);
}

.abey.abey--dark .abey-list__table tbody tr:hover td {
  background: rgba(56, 189, 248, 0.08);
}

.abey-list__table td:last-child:not([colspan]) {
  width: 1%;
  white-space: nowrap;
}

td.abey-list__actions,
th.abey-list__th-actions {
  text-align: end;
  white-space: normal;
}

td.abey-list__actions .abey-btn--sm {
  margin: 0.1rem 0.15rem;
  vertical-align: middle;
}

.abey-list__table tbody tr:last-child td {
  border-bottom: none;
}

.abey-list__table tbody tr[data-row-id]:nth-child(odd) td {
  background: var(--abey-surface-elev, #fcfcfd);
}

.abey.abey--dark .abey-list__table tbody tr[data-row-id]:nth-child(odd) td {
  background: #151b2a;
}

.abey.abey--dark abey-input input.abey-input[type="file"]::file-selector-button {
  background: var(--abey-surface-elev);
  border-color: var(--abey-border-strong);
  color: var(--abey-text);
}

.abey.abey--dark abey-input input.abey-input[type="file"]::file-selector-button:hover {
  border-color: var(--abey-accent);
  color: var(--abey-accent);
}

.abey-list__status,
.abey-list__status[role="alert"] {
  text-align: center;
  color: var(--abey-text-muted);
  font-style: italic;
  padding: var(--abey-space-5) !important;
}

.abey-list__pager {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: var(--abey-space-2);
  padding: var(--abey-space-3) var(--abey-space-4);
  border-top: 1px solid var(--abey-border);
  background: var(--abey-surface-elev);
}

.abey-list__pager-info {
  font-size: 0.82rem;
  color: var(--abey-text-muted);
  min-width: 12rem;
  text-align: center;
}

td.abey-list__status[role="alert"] {
  color: var(--abey-error) !important;
  font-style: normal;
  font-weight: 500;
  background: var(--abey-error-bg);
}

/* --- Formulario --- */
.abey-form form {
  margin: 0;
  padding: var(--abey-space-4) var(--abey-space-5) var(--abey-space-5);
}

@media (min-width: 1025px) {
  .abey-form:not(.abey-form--stacked) form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--abey-space-4);
    align-items: start;
  }

  .abey-form:not(.abey-form--stacked) form>.abey-form__message,
  .abey-form:not(.abey-form--stacked) form>.abey-form__actions {
    grid-column: 1 / -1;
  }

  .abey-form:not(.abey-form--stacked) form>.abey-form__radio-group {
    grid-column: 1 / -1;
  }

  .abey-form:not(.abey-form--stacked) form>.abey-field:only-child {
    grid-column: 1 / -1;
  }

  .abey-form:not(.abey-form--stacked) form>.abey-field:last-child:nth-child(odd):not(:has(> abey-radio)) {
    grid-column: 1 / -1;
  }
}

@media (max-width: 1024px) {
  .abey-form:not(.abey-form--stacked) form {
    display: flex;
    flex-direction: column;
    gap: var(--abey-space-4);
  }
}

.abey-form form>.abey-form__actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--abey-space-3);
  align-items: center;
  margin-top: var(--abey-space-2);
}

/* Cuando las acciones se mueven dentro del shell de pesta├▒as, ya no son hijo directo de `form`. */
.abey-form .abey-form__actions.abey-form__actions--in-tabshell {
  margin-top: var(--abey-space-4);
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 1.25rem;
}

.abey-form .abey-form__actions.abey-form__actions--in-tabshell>*+* {
  margin-left: 0.25rem;
  /* fallback si el gap no aplica por alg├║n motivo */
}

.abey-form .abey-form__actions.abey-form__actions--in-tabshell .abey-btn--primary {
  margin-left: auto;
}

.abey-form form>.abey-form__actions .abey-btn--primary {
  justify-self: start;
  min-width: 9rem;
  padding-inline: 1.35rem;
}

.abey-form__message {
  margin: 0 0 var(--abey-space-4);
  padding: var(--abey-space-2) var(--abey-space-3);
  border-radius: var(--abey-radius-sm);
  color: var(--abey-error);
  background: var(--abey-error-bg);
  font-size: 0.9rem;
  border: 1px solid rgba(220, 38, 38, 0.2);
}

/* Formulario con cuerpo scroll + pesta├▒as (objetos anidados) y/o paginaci├│n de campos ra├¡z */
.abey-form.abey-form--stacked form {
  display: flex;
  flex-direction: column;
  gap: var(--abey-space-4);
}

.abey-form--stacked form>.abey-form__main {
  display: flex;
  flex-direction: column;
  gap: var(--abey-space-4);
  min-height: 0;
  max-height: min(72vh, 38rem);
}

.abey-form__root-wrap {
  overflow-y: auto;
  flex: 1 1 auto;
  min-height: 0;
  min-width: 0;
  width: 100%;
  padding-right: 2px;
}

.abey-form__pages {
  display: flex;
  flex-direction: column;
  gap: 0;
  width: 100%;
  min-width: 0;
}

.abey-form__page {
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.abey-form__pager {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--abey-space-3);
  margin-bottom: var(--abey-space-3);
}

.abey-form__pager-info {
  flex: 1 1 8rem;
  text-align: center;
  font-size: 0.85rem;
  color: var(--abey-text-muted);
}

.abey-form__tabs {
  display: flex;
  flex-direction: column;
  gap: var(--abey-space-3);
  flex: 0 0 auto;
  min-height: 0;
  border-top: 1px solid var(--abey-border);
  padding-top: var(--abey-space-3);
}

.abey-form__tablist {
  display: flex;
  flex-wrap: wrap;
  gap: var(--abey-space-2);
}

.abey-form__tab {
  padding: 0.45rem 0.85rem;
  border-radius: var(--abey-radius-sm);
  border: 1px solid var(--abey-border);
  background: var(--abey-surface-elev);
  color: var(--abey-text-muted);
  font-size: 0.9rem;
  cursor: pointer;
}

.abey-form__tab[aria-selected="true"] {
  border-color: var(--abey-accent);
  background: rgba(37, 99, 235, 0.08);
  color: var(--abey-text);
  font-weight: 600;
}

.abey-form__tabpanels {
  min-height: 0;
}

.abey-form__tabpanel {
  overflow-y: auto;
  max-height: min(40vh, 20rem);
  padding-right: 2px;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

/* P├íginas/pesta├▒as ocultas: `display:none` en `[hidden]`. */
.abey-form__tabpanel[hidden],
.abey-form__page[hidden] {
  display: none !important;
}

/**
 * Formulario apilado (paginaci├│n ra├¡z / pesta├▒as): grid **1 col** en m├│vil/tablet;
 * **2 columnas** desde ~1025px (pantalla de computadora), con reglas que reducen huecos.
 */
.abey-form__field-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: var(--abey-space-4);
  align-items: start;
  width: 100%;
}

.abey-form__field-grid>.abey-field {
  min-width: 0;
}

.abey-form__field-grid>.abey-form__radio-group {
  display: flex;
  flex-direction: column;
  gap: var(--abey-space-2);
  min-width: 0;
  width: 100%;
}

.abey-form__field-grid>.abey-form__radio-group>.abey-field {
  width: 100%;
  max-width: none;
  min-width: 0;
}

/** Radios + campos siguientes (montaje `mount-form`): en m├│vil se apilan; en escritorio, 2 columnas dentro del split. */
.abey-form__field-split {
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.abey-form__field-aside {
  display: flex;
  flex-direction: column;
  gap: var(--abey-space-4);
  min-width: 0;
  width: 100%;
  box-sizing: border-box;
}

@media (max-width: 1024px) {
  .abey-form__field-split {
    display: flex;
    flex-direction: column;
    gap: var(--abey-space-4);
  }
}

@media (min-width: 1025px) {
  .abey-form__field-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  /** Grupo de radios solo (sin `.abey-form__field-aside`): sigue ocupando toda la fila del grid principal. */
  .abey-form__field-grid>.abey-form__radio-group {
    grid-column: 1 / -1;
  }

  /** Radios a la izquierda, select/checkbox siguientes a la derecha */
  .abey-form__field-grid>.abey-form__field-split {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--abey-space-4);
    align-items: start;
  }

  .abey-form__field-grid>.abey-field:only-child {
    grid-column: 1 / -1;
  }

  /** ├Ültimo hijo impar: qued├│ solo en la ├║ltima fila (p. ej. checkbox final) */
  .abey-form__field-grid>.abey-field:last-child:nth-child(odd):not(:has(> abey-radio)) {
    grid-column: 1 / -1;
  }

  /**
   * Campo antes de radios o antes del bloque split (radios + lateral): fila completa
   * (p. ej. bio antes de rol + nivel).
   */
  .abey-form__field-grid>.abey-field:has(+ .abey-form__radio-group),
  .abey-form__field-grid>.abey-field:has(+ .abey-form__field-split) {
    grid-column: 1 / -1;
  }
}

/* Grid y filas ocupan el ancho del bloque; los inputs/select no quedan capados a 32rem */
.abey-form .abey-form__field-grid,
.abey-form .abey-form__root-wrap,
.abey-form--stacked form>.abey-form__main {
  width: 100%;
}

.abey-form .abey-field {
  min-width: 0;
  width: 100%;
  max-width: none;
  box-sizing: border-box;
}

.abey-form abey-input,
.abey-form abey-select.abey-field__combo {
  max-width: 100%;
  width: 100%;
  box-sizing: border-box;
}

.abey-form .abey-input {
  max-width: 100%;
  box-sizing: border-box;
}

.abey-field {
  display: block;
  margin-bottom: var(--abey-space-4);
}

/* Checkbox / radio: control a la izquierda, etiqueta a la derecha */
.abey-field:has(> abey-checkbox),
.abey-field:has(> abey-radio) {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: var(--abey-space-3);
  flex-wrap: nowrap;
}

.abey-field:has(> abey-checkbox) .abey-field__label,
.abey-field:has(> abey-radio) .abey-field__label {
  order: 2;
  flex: 1;
  min-width: 0;
  margin-bottom: 0;
  padding-top: 0.2rem;
  line-height: 1.35;
}

.abey-field:has(> abey-checkbox) abey-checkbox,
.abey-field:has(> abey-radio) abey-radio {
  order: 1;
  margin-top: 0.1rem;
}

/* Hosts de custom elements (uikit) */
abey-checkbox,
abey-radio {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  max-width: 100%;
}

abey-line-items {
  display: block;
  width: 100%;
  max-width: 100%;
}

abey-input {
  display: block;
  width: 100%;
  max-width: 32rem;
}

abey-input input.abey-input {
  margin: 0;
}

abey-input input.abey-input[type="file"] {
  padding: 0.5rem 0;
  font-size: 0.875rem;
  cursor: pointer;
  border-style: dashed;
}

abey-input input.abey-input[type="file"]::file-selector-button {
  margin-right: var(--abey-space-3);
  padding: 0.4rem 0.85rem;
  font: inherit;
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--abey-text);
  background: var(--abey-surface-elev);
  border: 1px solid var(--abey-border-strong);
  border-radius: var(--abey-radius-sm);
  cursor: pointer;
  transition: background 0.12s, border-color 0.12s, color 0.12s;
}

abey-input input.abey-input[type="file"]::file-selector-button:hover {
  background: var(--abey-surface);
  border-color: var(--abey-accent);
  color: var(--abey-accent);
}

abey-select.abey-field__combo {
  display: block;
  position: relative;
  width: 100%;
  max-width: 32rem;
}

/* Tras reglas globales `abey-input` / `abey-select`: mayor especificidad para el grid ancho */
.abey-form.abey-form--full abey-input,
.abey-form.abey-form--full .abey-input,
abey-form.abey-form.abey-form--full abey-input,
abey-form.abey-form.abey-form--full .abey-input {
  max-width: 100%;
  width: 100%;
  box-sizing: border-box;
}

.abey-form.abey-form--full abey-select.abey-field__combo,
abey-form.abey-form.abey-form--full abey-select.abey-field__combo {
  max-width: 100%;
  width: 100%;
  box-sizing: border-box;
}

.abey-select-comboRow {
  display: flex;
  align-items: stretch;
  gap: 0.35rem;
  width: 100%;
}

.abey-select-comboRow>.abey-input {
  flex: 1;
  min-width: 0;
}

button.abey-select-clear {
  flex-shrink: 0;
  align-self: center;
  width: 2rem;
  height: 2rem;
  margin: 0;
  padding: 0;
  font: inherit;
  font-size: 1.25rem;
  line-height: 1;
  color: var(--abey-text-muted);
  background: transparent;
  border: 1px solid transparent;
  border-radius: var(--abey-radius-sm);
  cursor: pointer;
  transition: color 0.12s, background 0.12s, border-color 0.12s;
}

button.abey-select-clear:hover:not(:disabled) {
  color: var(--abey-text);
  background: var(--abey-surface-elev);
  border-color: var(--abey-border);
}

button.abey-select-clear:disabled {
  cursor: not-allowed;
  opacity: 0.45;
}

/* Men├║ del combo select (clases uikit) */
.abey .abey-select-menu {
  box-shadow: var(--abey-shadow-lg);
  border-radius: var(--abey-radius-sm) !important;
}

.abey .abey-select-option {
  font: inherit;
  font-size: 0.875rem;
  color: var(--abey-text);
  cursor: pointer;
  transition: background 0.1s ease;
}

.abey .abey-select-option:hover {
  background: var(--abey-surface-elev) !important;
}

.abey-field--inlineOptional {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--abey-space-2);
  margin-bottom: var(--abey-space-3);
}

@media (min-width: 1025px) {
  .abey-form:not(.abey-form--stacked) form>.abey-field--inlineOptional {
    grid-column: 1 / -1;
  }

  .abey-form.abey-form--stacked form>.abey-field--inlineOptional {
    align-self: stretch;
    width: 100%;
    box-sizing: border-box;
  }
}

.abey-checkbox,
.abey-radio {
  width: 1.125rem;
  height: 1.125rem;
  max-width: none;
  margin: 0;
  flex-shrink: 0;
  accent-color: var(--abey-accent);
  cursor: pointer;
}

.abey-checkbox:focus-visible,
.abey-radio:focus-visible {
  outline: 2px solid var(--abey-accent);
  outline-offset: 3px;
  border-radius: 2px;
}

.abey-field__label {
  display: block;
  font-size: 0.82rem;
  font-weight: 600;
  letter-spacing: 0.01em;
  color: var(--abey-text);
  margin-bottom: var(--abey-space-1);
}

/* Etiquetas sobre input/select de ancho completo (no checkbox/radio) */
.abey-field:not(:has(> abey-checkbox)):not(:has(> abey-radio))>.abey-field__label {
  color: var(--abey-text-muted);
  font-weight: 500;
}

.abey-input {
  display: block;
  width: 100%;
  max-width: 32rem;
  margin-top: 0;
  padding: 0.6rem 0.85rem;
  font: inherit;
  font-size: 0.9375rem;
  line-height: 1.45;
  color: var(--abey-text);
  background: var(--abey-surface);
  border: 1px solid var(--abey-border);
  border-radius: var(--abey-radius-sm);
  transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
}

.abey-input::placeholder {
  color: var(--abey-text-muted);
  opacity: 0.85;
}

.abey-input:hover:not(:read-only):not(:disabled):not([aria-invalid="true"]) {
  border-color: var(--abey-border-strong);
}

.abey-input:focus {
  outline: none;
  border-color: var(--abey-accent);
  box-shadow: 0 0 0 3px var(--abey-focus);
}

.abey-input:focus-visible {
  outline: none;
  border-color: var(--abey-accent);
  box-shadow: 0 0 0 3px var(--abey-focus);
}

.abey-input[aria-invalid="true"] {
  border-color: var(--abey-error);
  background: var(--abey-error-bg);
}

.abey-input[aria-invalid="true"]:focus {
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--abey-error) 45%, transparent);
}

.abey-input:read-only {
  background: var(--abey-surface-elev);
  color: var(--abey-text-muted);
  cursor: default;
}

.abey-input:disabled {
  opacity: 0.55;
  cursor: not-allowed;
  background: var(--abey-surface-elev);
}

/*
 * Native <select> outside the combo overlay (toolbar, templates, demos).
 * Combo search field already uses `.abey-input`; this covers plain <select>.
 */
.abey select {
  display: block;
  max-width: 100%;
  margin-top: 0;
  padding: 0.55rem 0.75rem;
  font: inherit;
  font-size: 0.9375rem;
  line-height: 1.45;
  color: var(--abey-text);
  background-color: var(--abey-surface);
  border: 1px solid var(--abey-border);
  border-radius: var(--abey-radius-sm);
  accent-color: var(--abey-accent);
  cursor: pointer;
  transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
}

.abey select:hover:not(:disabled) {
  border-color: var(--abey-border-strong);
}

.abey select:focus {
  outline: none;
  border-color: var(--abey-accent);
  box-shadow: 0 0 0 3px var(--abey-focus);
}

.abey select:focus-visible {
  outline: none;
  border-color: var(--abey-accent);
  box-shadow: 0 0 0 3px var(--abey-focus);
}

.abey select:disabled {
  opacity: 0.55;
  cursor: not-allowed;
  background: var(--abey-surface-elev);
}

.abey-input[type="number"] {
  font-variant-numeric: tabular-nums;
}

.abey-field__select-wrap {
  display: grid;
  gap: var(--abey-space-2);
  max-width: 32rem;
}

.abey-form .abey-field__select-wrap,
.abey-form.abey-form--full .abey-field__select-wrap,
abey-form.abey-form.abey-form--full .abey-field__select-wrap {
  max-width: 100%;
  width: 100%;
  box-sizing: border-box;
}

.abey-field__error {
  display: block;
  font-size: 0.8rem;
  color: var(--abey-error);
  margin-top: var(--abey-space-1);
  font-weight: 500;
}

/* --- Botones (toolbar + acciones) --- */
.abey-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font: inherit;
  font-size: 0.875rem;
  font-weight: 500;
  line-height: 1.2;
  padding: 0.5rem 1rem;
  border-radius: var(--abey-radius-sm);
  border: 1px solid var(--abey-border-strong, #c9ced6);
  background: var(--abey-surface);
  color: var(--abey-text);
  cursor: pointer;
  transition: background 0.12s, border-color 0.12s, color 0.12s, box-shadow 0.12s;
}

.abey-btn:hover {
  background: var(--abey-surface-elev);
  border-color: var(--abey-border);
}

.abey-btn:focus {
  outline: none;
  box-shadow: 0 0 0 3px var(--abey-focus);
}

.abey-btn:disabled {
  opacity: 0.55;
  cursor: not-allowed;
}

/* Primario: env├¡o, acci├│n principal */
.abey-btn--primary {
  background: var(--abey-accent);
  color: var(--abey-on-accent, #fff);
  border-color: var(--abey-accent);
}

.abey-btn--primary:hover:not(:disabled) {
  background: var(--abey-accent-hover);
  border-color: var(--abey-accent-hover);
}

.abey-btn--sm {
  font-size: 0.8rem;
  padding: 0.35rem 0.6rem;
}

.abey-btn--success {
  color: #166534;
  background: #dcfce7;
  border-color: #86efac;
}

.abey-btn--success:hover:not(:disabled) {
  color: #14532d;
  background: #bbf7d0;
  border-color: #4ade80;
}

.abey-btn--danger {
  color: #991b1b;
  background: #fee2e2;
  border-color: #fca5a5;
}

.abey-btn--danger:hover:not(:disabled) {
  color: #7f1d1d;
  background: #fecaca;
  border-color: #f87171;
}

/* Contenido de `setSanitizedHtml` (marca expl├¡cita; no estilos de confianza, solo contenci├│n) */
.abey-html[data-abey-html="1"] {
  max-width: 100%;
  overflow-wrap: break-word;
}

/* Llamada / pre (estado de flujo) */
.abey-callout {
  margin: var(--abey-space-3) 0;
  padding: var(--abey-space-3) var(--abey-space-4);
  background: var(--abey-surface, #fff);
  border: 1px solid var(--abey-border, #e1e4e8);
  border-radius: var(--abey-radius, 8px);
  font-family: var(--abey-font-mono, monospace);
  font-size: 0.8rem;
  line-height: 1.4;
  color: var(--abey-text-muted);
  max-height: 6rem;
  overflow: auto;
  white-space: pre-wrap;
}

.abey-app .abey-callout {
  max-width: 960px;
  margin-left: auto;
  margin-right: auto;
}

/* --- Aplicaci├│n con layout (app bar + sidebar) --- */
html {
  height: 100%;
}

.abey-shell-app {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--abey-bg);
  color: var(--abey-text);
}

.abey-shell-app>.abey-shell,
.abey-shell {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-height: 0;
}

/* App bar */
.abey-appbar {
  flex-shrink: 0;
  height: var(--abey-appbar-h);
  border-bottom: 1px solid var(--abey-border);
  background: var(--abey-surface);
  box-shadow: 0 1px 0 rgba(15, 23, 42, 0.04);
  z-index: 10;
}

/* Pegada al hacer scroll viewport (landing o shell sin alto fijo interno). */
.abey-shell>.abey-appbar {
  position: sticky;
  top: 0;
  z-index: 12;
}

.abey-appbar__inner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: var(--abey-space-3);
  min-height: var(--abey-appbar-h);
  max-width: 100%;
  margin: 0;
  padding: 0 1.25rem;
}

.abey-appbar__brand {
  display: flex;
  flex-direction: column;
  gap: 0.1rem;
  line-height: 1.2;
  min-width: 0;
}

.abey-appbar__title {
  font-weight: 700;
  font-size: 1.05rem;
  letter-spacing: -0.02em;
  color: var(--abey-text);
}

.abey-appbar__subtitle {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--abey-text-muted);
}

.abey-appbar__nav {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--abey-space-1) var(--abey-space-3);
}

/* App bar: plantilla ÔÇ£dashboardÔÇØ (franja de marca + acciones) */
.abey-appbar--dashboard {
  height: auto;
  min-height: var(--abey-appbar-h);
  background: linear-gradient(180deg, var(--abey-surface) 0%, color-mix(in srgb, var(--abey-surface) 96%, var(--abey-bg) 4%) 100%);
  border-bottom: 1px solid color-mix(in srgb, var(--abey-border) 88%, transparent);
  box-shadow: 0 1px 0 rgba(15, 23, 42, 0.04), 0 8px 24px -14px rgba(15, 23, 42, 0.12);
}

.abey-appbar--dashboard .abey-appbar__inner {
  min-height: var(--abey-appbar-h);
  padding: 0 1.25rem 0 0;
  align-items: stretch;
}

.abey-appbar__row {
  display: flex;
  flex: 1;
  align-items: stretch;
  width: 100%;
  min-height: var(--abey-appbar-h);
}

/* Overlay / drawer (dashboard): Ôÿ░ en la app bar ÔÇö no pegado al outlet de contenido. */
.abey-sidebar__toggle.abey-appbar__nav-toggle {
  display: none;
  flex-shrink: 0;
  align-self: center;
  margin: 0 0.6rem 0 0.75rem;
}

@media (min-width: 901px) {

  .abey-shell[data-abey-nav-mode="overlay"] .abey-sidebar__toggle.abey-appbar__nav-toggle,
  .abey-shell[data-abey-nav-mode="drawer"] .abey-sidebar__toggle.abey-appbar__nav-toggle {
    display: inline-flex;
  }

  .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar .abey-sidebar__toggle:not(.abey-appbar__nav-toggle),
  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar .abey-sidebar__toggle:not(.abey-appbar__nav-toggle) {
    display: none !important;
  }
}

@media (max-width: 900px) {

  .abey-shell[data-abey-nav-mode="overlay"] .abey-sidebar__toggle.abey-appbar__nav-toggle,
  .abey-shell[data-abey-nav-mode="drawer"] .abey-sidebar__toggle.abey-appbar__nav-toggle {
    display: none !important;
  }
}

.abey-appbar__mark {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 0.1rem;
  min-width: 8.85rem;
  padding: 0.5rem 1.35rem 0.52rem 1.25rem;
  background:
    radial-gradient(120% 140% at 10% -20%, rgba(255, 255, 255, 0.22) 0%, transparent 45%),
    linear-gradient(145deg, #5b21b6 0%, #4338ca 42%, #5b21b6 72%, #6d28d9 100%);
  color: #fff;
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.14),
    inset 0 -1px 0 rgba(0, 0, 0, 0.12);
}

.abey-appbar__mark-title {
  font-weight: 800;
  font-size: 1.1rem;
  letter-spacing: -0.02em;
  line-height: 1.2;
  color: #fff;
}

.abey-appbar__mark-sub {
  font-size: 0.65rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: rgba(255, 255, 255, 0.85);
}

/* T├¡tulo + subt├¡tulo dentro de la marca dashboard (cabecera o franja lateral). */
.abey-appbar__mark-text {
  display: flex;
  flex-direction: column;
  gap: 0.1rem;
  align-items: inherit;
  text-align: inherit;
  min-width: 0;
}

/* Opcional **`brandLogoSrc`**: jam├ís duplicar con el jewel `::before`. */
.abey-appbar__mark:has(.abey-appbar__mark-logo)::before {
  content: none;
  display: none;
}

.abey-appbar__mark-logo {
  flex-shrink: 0;
  height: 2rem;
  width: auto;
  max-width: 10rem;
  object-fit: contain;
}

/** Fila **Abey** + **JS** (`brandTitleSplit`). */
.abey-appbar__mark-heading {
  display: inline-flex;
  flex-wrap: nowrap;
  align-items: baseline;
  gap: 0;
  max-width: 100%;
  min-width: 0;
  font-weight: inherit;
  font-size: inherit;
  line-height: 1.2;
  letter-spacing: inherit;
}

/** Tramo s├│lido (logo Abey┬À┬À┬À). En franja violeta t├¡pico blanco. */
.abey-appbar--dashboard .abey-appbar__mark-title--lead {
  color: var(--abey-brand-mark-lead, #ffffff);
}

/** Tramo con gradiente (logo ┬À┬À┬ÀJS ÔÇö azul ÔåÆ ├¡ndigo ÔåÆ violeta, afinable con vars). */
.abey-appbar__mark-title--tail {
  background: linear-gradient(
    92deg,
    var(--abey-brand-tail-a, #38bdf8) 0%,
    var(--abey-brand-tail-b, #6366f1) 46%,
    var(--abey-brand-tail-c, #7c3aed) 100%
  );
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  -webkit-text-fill-color: transparent;
}

/* Dashboard: marca alineada al ancho real del sidebar (--abey-sidebar-w). */
.abey-appbar--dashboard .abey-appbar__mark {
  flex: 0 0 var(--abey-sidebar-w);
  width: var(--abey-sidebar-w);
  max-width: var(--abey-sidebar-w);
  min-width: 0;
  box-sizing: border-box;
  align-items: center;
  text-align: center;
  padding: 0.5rem 0.75rem;
}

.abey-appbar__spacer {
  flex: 1;
  min-width: 0.5rem;
}

/* Optional slot before action buttons (`appBarInset`, e.g. search). */
.abey-appbar__inset {
  flex: 0 1 auto;
  min-width: 0;
  max-width: 28rem;
  display: flex;
  align-items: center;
  padding: 0 0.35rem;
  box-sizing: border-box;
}

.abey-appbar__tools {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: flex-end;
  gap: 0.5rem;
  padding: 0.35rem 0 0.35rem 0.5rem;
}

/*
 * Acciones derecha (**soft UI ┬À iconos**) ÔÇö superficie tipo ÔÇ£tileÔÇØ redondeada, borde ligero,
 * sombra suave (**referencia dashboards** tipo ajustes / notificaciones en bloque claros).
 */
.abey-appbar__action {
  --abey-appbar-action-radius: 0.6875rem;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2.5rem;
  height: 2.5rem;
  padding: 0;
  font-size: 1.05rem;
  line-height: 1;
  border: 1px solid color-mix(in srgb, var(--abey-border) 92%, var(--abey-text) 8%);
  border-radius: var(--abey-appbar-action-radius);
  background: color-mix(in srgb, var(--abey-surface-elev, #f8fafc) 94%, var(--abey-bg) 6%);
  color: color-mix(in srgb, var(--abey-text-muted) 86%, var(--abey-text) 14%);
  cursor: pointer;
  box-shadow:
    0 1px 0 rgba(255, 255, 255, 0.58) inset,
    0 1px 2px rgba(15, 23, 42, 0.04),
    0 6px 16px rgba(15, 23, 42, 0.05);
  transition:
    background 0.14s ease,
    color 0.14s ease,
    border-color 0.14s ease,
    box-shadow 0.14s ease,
    transform 0.14s ease;
}

.abey-appbar__action:hover,
.abey-appbar__action:focus-visible {
  color: color-mix(in srgb, var(--abey-text) 94%, var(--abey-accent));
  background: color-mix(in srgb, var(--abey-surface) 94%, var(--abey-accent) 4%);
  border-color: color-mix(in srgb, var(--abey-accent) 22%, var(--abey-border));
  box-shadow:
    0 1px 0 rgba(255, 255, 255, 0.45) inset,
    0 0 0 1px color-mix(in srgb, var(--abey-accent) 12%, transparent),
    0 8px 22px rgba(15, 23, 42, 0.08);
  outline: none;
}

.abey-appbar__action:active {
  transform: translateY(0.5px) scale(0.98);
  box-shadow:
    0 1px 0 rgba(255, 255, 255, 0.42) inset,
    0 1px 2px rgba(15, 23, 42, 0.06);
}

.abey.abey--dark .abey-appbar--dashboard .abey-appbar__action {
  border-color: color-mix(in srgb, var(--abey-border) 78%, transparent);
  background: color-mix(in srgb, var(--abey-surface-elev) 88%, transparent);
  color: color-mix(in srgb, var(--abey-text-muted) 78%, var(--abey-text) 22%);
  box-shadow:
    0 1px 0 rgba(255, 255, 255, 0.04) inset,
    0 2px 10px rgba(0, 0, 0, 0.32);
}

.abey.abey--dark .abey-appbar--dashboard .abey-appbar__action:hover,
.abey.abey--dark .abey-appbar--dashboard .abey-appbar__action:focus-visible {
  color: color-mix(in srgb, var(--abey-text) 92%, var(--abey-accent));
  border-color: color-mix(in srgb, var(--abey-accent) 28%, var(--abey-border));
  background: color-mix(in srgb, var(--abey-surface-elev) 76%, transparent);
  box-shadow:
    0 1px 0 rgba(255, 255, 255, 0.06) inset,
    0 0 0 1px color-mix(in srgb, var(--abey-accent) 22%, transparent),
    0 10px 28px rgba(0, 0, 0, 0.4);
}

.abey-appbar__action:focus:not(:focus-visible) {
  outline: none;
}

.abey-appbar__action--labeled {
  width: auto;
  min-width: 2.4rem;
  padding: 0 0.65rem;
  gap: 0.4rem;
  border-radius: var(--abey-appbar-action-radius);
}

.abey-appbar__action-txt {
  font-size: 0.82rem;
  font-weight: 600;
  max-width: 10rem;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.abey-appbar__action i {
  font-size: 1.02rem;
  line-height: 1;
  opacity: 0.92;
}

.abey-appbar__action.abey-appbar__action--theme i {
  font-size: 0.94rem;
  opacity: 0.94;
}

/* App bar ┬À men├║ contextual (cuenta / ÔÇª) ÔÇö flota sobre contenido (**no clip** en **`.abey-appbar__tools`**). */
.abey-appbar__dropdown {
  position: relative;
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
}

.abey-appbar__dropdown-panel {
  position: absolute;
  top: calc(100% + 0.4rem);
  right: 0;
  z-index: 120;
  min-width: 12.75rem;
  max-width: min(18rem, calc(100vw - 2rem));
  padding: 0.4rem;
  border-radius: 0.85rem;
  border: 1px solid color-mix(in srgb, var(--abey-border) 90%, var(--abey-text) 10%);
  background: color-mix(in srgb, var(--abey-surface) 96%, var(--abey-bg) 4%);
  box-shadow:
    0 1px 0 rgba(255, 255, 255, 0.55) inset,
    0 8px 28px rgba(15, 23, 42, 0.1),
    0 2px 8px rgba(15, 23, 42, 0.05);
}

.abey-appbar__dropdown-item {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 0.55rem;
  width: 100%;
  margin: 0;
  padding: 0.48rem 0.62rem;
  border: none;
  border-radius: 0.62rem;
  font: inherit;
  font-size: 0.9rem;
  font-weight: 500;
  letter-spacing: -0.01em;
  line-height: 1.25;
  text-align: left;
  text-decoration: none;
  color: color-mix(in srgb, var(--abey-text-muted) 72%, var(--abey-text) 28%);
  background: transparent;
  cursor: pointer;
  transition: background 0.12s ease, color 0.12s ease;
}

.abey-appbar__dropdown-item:hover,
.abey-appbar__dropdown-item:focus-visible {
  outline: none;
  color: var(--abey-text);
  background: color-mix(in srgb, var(--abey-accent) 8%, var(--abey-surface));
}

.abey-appbar__dropdown-item i {
  width: 1.1rem;
  font-size: 0.92rem;
  text-align: center;
  opacity: 0.9;
}

.abey-appbar__dropdown-item-label {
  flex: 1;
  min-width: 0;
  overflow-wrap: anywhere;
}

.abey.abey--dark .abey-appbar--dashboard .abey-appbar__dropdown-panel {
  border-color: color-mix(in srgb, var(--abey-border) 72%, transparent);
  background: color-mix(in srgb, var(--abey-surface-elev) 94%, transparent);
  box-shadow:
    0 1px 0 rgba(255, 255, 255, 0.05) inset,
    0 12px 36px rgba(0, 0, 0, 0.45);
}

.abey.abey--dark .abey-appbar--dashboard .abey-appbar__dropdown-item:hover,
.abey.abey--dark .abey-appbar--dashboard .abey-appbar__dropdown-item:focus-visible {
  background: color-mix(in srgb, var(--abey-accent) 14%, var(--abey-surface-elev));
}

.abey-appbar__action--avatar {
  overflow: hidden;
  padding: 2px;
}

.abey-appbar__action-avatar-img {
  display: block;
  width: 100%;
  height: 100%;
  max-width: 2rem;
  max-height: 2rem;
  object-fit: cover;
  border-radius: calc(var(--abey-appbar-action-radius, 0.6875rem) - 2px);
}

.abey-shell--dashboard .abey-outlet--dashboard {
  background:
    radial-gradient(1200px 400px at 18% -8%, rgba(99, 102, 241, 0.05) 0%, transparent 55%),
    linear-gradient(175deg, #eef3f9 0%, #e9eef6 52%, #e7ecf4 100%);
}

.abey-shell-app.abey--dark .abey-shell--dashboard .abey-outlet--dashboard {
  background:
    radial-gradient(980px 360px at 12% -6%, rgba(56, 189, 248, 0.07) 0%, transparent 50%),
    linear-gradient(180deg, var(--abey-bg) 0%, var(--abey-surface-elev) 100%);
}

.abey-shell--dashboard .abey-sidebar--dashboard .abey-nav-link--sidebar {
  padding: 0.55rem 0.72rem;
}

/* Cuerpo: fila (sidebar + main) */
.abey-shell__body {
  display: flex;
  flex: 1;
  min-height: 0;
  align-items: stretch;
}

/* Sidebar (admin) */
.abey-sidebar {
  display: flex;
  flex-direction: column;
  position: relative;
  flex: 0 0 var(--abey-sidebar-w);
  max-width: 100%;
  min-width: 0;
  background: var(--abey-surface-elev);
  border-right: 1px solid var(--abey-border);
}

.abey-sidebar__nav {
  display: flex;
  flex-direction: column;
  flex: 1 1 auto;
  min-height: 0;
  padding: var(--abey-space-2) 0;
  position: relative;
}

.abey-sidebar__inner {
  flex: 1;
  overflow: auto;
  padding: 0 0.35rem 1rem 0.75rem;
}

.abey-shell--dashboard .abey-sidebar__inner {
  padding: 0.15rem 0.4rem 1.25rem 0.7rem;
  scrollbar-width: thin;
  scrollbar-color: rgba(100, 116, 139, 0.32) transparent;
}

.abey-shell--dashboard .abey-sidebar__inner::-webkit-scrollbar {
  width: 7px;
}

.abey-shell--dashboard .abey-sidebar__inner::-webkit-scrollbar-thumb {
  border-radius: 999px;
  background: rgba(100, 116, 139, 0.28);
  border: 2px solid transparent;
  background-clip: padding-box;
}

.abey.abey--dark .abey-shell--dashboard .abey-sidebar__inner::-webkit-scrollbar-thumb {
  background: rgba(148, 163, 184, 0.22);
  border: 2px solid transparent;
  background-clip: padding-box;
}

.abey-shell--dashboard .abey-sidebar__inner::-webkit-scrollbar-button {
  display: none;
  width: 0;
  height: 0;
}

.abey-shell--dashboard .abey-sidebar__inner::-webkit-scrollbar-corner {
  background: transparent;
}

.abey-shell--dashboard .abey-sidebar__inner::-webkit-scrollbar-thumb:active {
  background: rgba(100, 116, 139, 0.42);
}

.abey.abey--dark .abey-shell--dashboard .abey-sidebar__inner::-webkit-scrollbar-thumb:hover {
  background: rgba(148, 163, 184, 0.36);
}

.abey.abey--dark .abey-shell--dashboard .abey-sidebar__inner::-webkit-scrollbar-thumb:active {
  background: color-mix(in srgb, var(--abey-accent) 45%, rgba(148, 163, 184, 0.32));
}

/* Admin dashboard: navegaci├│n m├ís legible y estado activo con acento lateral */
.abey-shell--dashboard .abey-sidebar .abey-nav-link--sidebar:not(.abey-nav-link--horizontal) {
  transition:
    background 0.22s cubic-bezier(0.32, 0.72, 0.25, 1),
    color 0.2s cubic-bezier(0.32, 0.72, 0.25, 1),
    border-color 0.2s ease,
    box-shadow 0.24s cubic-bezier(0.32, 0.72, 0.25, 1),
    transform 0.2s cubic-bezier(0.32, 0.72, 0.25, 1);
}

.abey-shell--dashboard .abey-sidebar .abey-nav-link--sidebar:hover:not([aria-current="page"]):not(.abey-nav-link--active),
.abey-shell--dashboard .abey-sidebar .abey-nav-link--sidebar:focus-visible:not([aria-current="page"]):not(.abey-nav-link--active) {
  transform: translateX(2px);
  box-shadow: 0 3px 12px rgba(37, 99, 235, 0.08);
}

.abey.abey--dark .abey-shell--dashboard .abey-sidebar .abey-nav-link--sidebar:hover:not([aria-current="page"]):not(.abey-nav-link--active),
.abey.abey--dark .abey-shell--dashboard .abey-sidebar .abey-nav-link--sidebar:focus-visible:not([aria-current="page"]):not(.abey-nav-link--active) {
  box-shadow: 0 3px 14px rgba(0, 0, 0, 0.28);
}

.abey-shell--dashboard .abey-sidebar .abey-nav-link[aria-current="page"].abey-nav-link--sidebar,
.abey-shell--dashboard .abey-sidebar .abey-nav-link--active.abey-nav-link--sidebar {
  position: relative;
  isolation: isolate;
  font-weight: 600;
  border-color: transparent;
  background:
    radial-gradient(120% 220% at 0% 50%, color-mix(in srgb, var(--abey-accent) 28%, transparent) 0%, transparent 68%),
    linear-gradient(96deg,
      color-mix(in srgb, var(--abey-accent) 13%, transparent) 0%,
      color-mix(in srgb, var(--abey-accent) 4%, transparent) 100%);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.52),
    0 0 0 1px color-mix(in srgb, var(--abey-accent) 9%, transparent),
    0 6px 22px rgba(37, 99, 235, 0.1);
}

.abey.abey--dark .abey-shell--dashboard .abey-sidebar .abey-nav-link[aria-current="page"].abey-nav-link--sidebar,
.abey.abey--dark .abey-shell--dashboard .abey-sidebar .abey-nav-link--active.abey-nav-link--sidebar {
  border-color: transparent;
  background:
    radial-gradient(130% 240% at 4% 50%, color-mix(in srgb, var(--abey-accent) 22%, transparent) 0%, transparent 74%),
    linear-gradient(96deg,
      color-mix(in srgb, var(--abey-accent) 16%, transparent) 0%,
      color-mix(in srgb, var(--abey-accent) 5%, transparent) 92%);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.065),
    0 0 0 1px color-mix(in srgb, var(--abey-accent) 12%, transparent),
    0 8px 28px rgba(0, 0, 0, 0.2),
    0 0 48px color-mix(in srgb, var(--abey-accent) 7%, transparent);
}

.abey-shell--dashboard .abey-sidebar .abey-nav-link[aria-current="page"].abey-nav-link--sidebar::before,
.abey-shell--dashboard .abey-sidebar .abey-nav-link--active.abey-nav-link--sidebar::before {
  content: "";
  position: absolute;
  left: 5px;
  top: 50%;
  transform: translateY(-50%);
  width: 2.5px;
  height: 48%;
  min-height: 0.95rem;
  border-radius: 999px;
  background: linear-gradient(180deg, var(--abey-accent) 0%, var(--abey-accent-hover) 100%);
  box-shadow:
    0 0 10px color-mix(in srgb, var(--abey-accent) 45%, transparent),
    0 0 14px color-mix(in srgb, var(--abey-accent) 22%, transparent);
  opacity: 0.92;
}

.abey-shell--dashboard .abey-sidebar .abey-nav-link--active.abey-nav-link--sidebar .abey-nav-link__ic,
.abey-shell--dashboard .abey-sidebar .abey-nav-link[aria-current="page"].abey-nav-link--sidebar .abey-nav-link__ic {
  background: color-mix(in srgb, var(--abey-accent) 24%, transparent);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.09);
}

.abey-shell--dashboard .abey-sidebar .abey-nav-tree__summary {
  border-radius: var(--abey-radius-sm);
  transition: background 0.15s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.15s;
}

.abey-shell--dashboard .abey-sidebar .abey-nav-tree__summary:hover,
.abey-shell--dashboard .abey-sidebar .abey-nav-tree__summary:focus-visible {
  box-shadow: 0 2px 8px rgba(15, 23, 42, 0.05);
}

.abey-shell--dashboard .abey-sidebar .abey-nav-tree__summary-ic {
  box-shadow: none;
}

/*
 * Sidebar columna oscura del sidebar: igual que el lienzo (`--abey-bg`), no `--abey-surface-elev`,
 * para no crear una segunda franja versus la marca/logo y el omega-default.dashboard.
 */
 .doc-site.abey-shell-app.abey--dark .abey-shell__body > .abey-sidebar.abey-sidebar--dashboard {
  background: var(--abey-bg);
  border-right: 1px solid color-mix(in srgb, var(--abey-border) 85%, transparent);
  box-shadow: none;
}

.doc-site.abey-shell-app.abey--dark .abey-shell__body > .abey-sidebar.abey-sidebar--dashboard .abey-sidebar__nav,
.doc-site.abey-shell-app.abey--dark .abey-shell__body > .abey-sidebar.abey-sidebar--dashboard .abey-sidebar__inner {
  background: transparent;
}

.abey-sidebar__toggle {
  display: none;
  margin: 0.35rem 0.75rem 0.5rem;
  width: 2.25rem;
  height: 2.25rem;
  font-size: 1.1rem;
  line-height: 1;
  border: 1px solid var(--abey-border);
  background: var(--abey-surface);
  color: var(--abey-text);
  border-radius: var(--abey-radius-sm);
  cursor: pointer;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* Outlet */
.abey-outlet {
  flex: 1;
  min-width: 0;
  padding: 1.25rem 1.5rem 2rem;
  overflow: auto;
  /* Menos shifting del ancho cuando la barra vertical aparece o desaparece al cambiar de ruta/alto. */
  scrollbar-gutter: stable;
  background: var(--abey-bg);
  --abey-route-ease: cubic-bezier(0.32, 0.72, 0.25, 1);
  --abey-route-dur-out: 105ms;
  --abey-route-dur-in: 145ms;
}

/* Outlet dashboard: mismo lenguaje que sidebar (sin flechas tipo Win, thumb fino) */
.abey-shell--dashboard .abey-outlet {
  scrollbar-width: thin;
  scrollbar-color: rgba(100, 116, 139, 0.3) transparent;
}

.abey.abey--dark .abey-shell--dashboard .abey-outlet {
  scrollbar-color: rgba(148, 163, 184, 0.2) transparent;
}

.abey-shell--dashboard .abey-outlet::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

.abey-shell--dashboard .abey-outlet::-webkit-scrollbar-button {
  display: none;
  width: 0;
  height: 0;
}

.abey-shell--dashboard .abey-outlet::-webkit-scrollbar-track {
  background: transparent;
}

.abey-shell--dashboard .abey-outlet::-webkit-scrollbar-corner {
  background: transparent;
}

.abey-shell--dashboard .abey-outlet::-webkit-scrollbar-thumb {
  border-radius: 999px;
  background: rgba(100, 116, 139, 0.28);
  border: 2px solid transparent;
  background-clip: padding-box;
}

.abey-shell--dashboard .abey-outlet::-webkit-scrollbar-thumb:hover {
  background: rgba(100, 116, 139, 0.4);
  border: 2px solid transparent;
  background-clip: padding-box;
}

.abey.abey--dark .abey-shell--dashboard .abey-outlet::-webkit-scrollbar-thumb {
  background: rgba(148, 163, 184, 0.22);
}

.abey.abey--dark .abey-shell--dashboard .abey-outlet::-webkit-scrollbar-thumb:hover {
  background: color-mix(in srgb, var(--abey-accent) 28%, rgba(148, 163, 184, 0.32));
}

.abey-outlet--landing {
  max-width: 100%;
  padding: 0;
}

/* Route transitions (soft refresh on navigation) */
.abey-outlet--leaving {
  opacity: 0;
  transform: translateY(3px) scale(0.996);
  transition:
    opacity var(--abey-route-dur-out) var(--abey-route-ease),
    transform var(--abey-route-dur-out) var(--abey-route-ease);
}

.abey-outlet--entering {
  opacity: 1;
  transform: translateY(0) scale(1);
  transition:
    opacity var(--abey-route-dur-in) var(--abey-route-ease),
    transform var(--abey-route-dur-in) var(--abey-route-ease);
}

@media (prefers-reduced-motion: reduce) {

  .abey-outlet--leaving,
  .abey-outlet--entering {
    transition: none !important;
    transform: none !important;
  }
}

/* Navegaci├│n (enlace interno) */
.abey-nav-stack {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.abey-nav-link {
  text-decoration: none;
  color: var(--abey-text-muted);
  font-size: 0.88rem;
  font-weight: 500;
  padding: 0.5rem 0.65rem;
  border-radius: var(--abey-radius-sm);
  border: 1px solid transparent;
  transition: background 0.12s, color 0.12s, border-color 0.12s;
}

.abey-nav-link--sidebar {
  display: block;
}

.abey-nav-link--with-icon.abey-nav-link--sidebar {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 0.55rem;
}

/* Sidebar: grupos anidados (`navChildren` ÔåÆ `<details>`) */
.abey-nav-tree {
  border-radius: var(--abey-radius-sm);
}

.abey-nav-tree+.abey-nav-tree,
.abey-nav-tree+.abey-nav-link--sidebar,
.abey-nav-link--sidebar+.abey-nav-tree {
  margin-top: 0.1rem;
}

.abey-nav-tree__summary {
  list-style: none;
  cursor: pointer;
  user-select: none;
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--abey-text);
  padding: 0.5rem 0.65rem;
  border-radius: var(--abey-radius-sm);
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 0.55rem;
  transition: background 0.12s, color 0.12s;
}

.abey-nav-tree__summary::-webkit-details-marker {
  display: none;
}

.abey-nav-tree__summary::marker {
  content: "";
}

.abey-nav-tree__summary:hover,
.abey-nav-tree__summary:focus {
  background: rgba(37, 99, 235, 0.08);
  outline: none;
}

.abey-nav-tree__summary-ic {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 1.65rem;
  height: 1.65rem;
  flex-shrink: 0;
  font-size: 0.95rem;
  line-height: 1;
  border-radius: 0.45rem;
  background: rgba(37, 99, 235, 0.08);
  color: var(--abey-text);
}

.abey-nav-tree__summary-ic i {
  font-size: 0.82rem;
  line-height: 1;
}

.abey-nav-tree__summary-txt {
  min-width: 0;
  flex: 1;
}

.abey-nav-tree__subs {
  display: flex;
  flex-direction: column;
  gap: 0.1rem;
  padding: 0.15rem 0 0.35rem 0.5rem;
  margin-left: 0.35rem;
  border-left: 1px solid var(--abey-border);
}

.abey-sidebar--dashboard .abey-nav-tree__summary {
  padding: 0.55rem 0.7rem;
}

.abey.abey--dark .abey-nav-tree__subs {
  border-left-color: rgba(148, 163, 184, 0.25);
}

.abey.abey--dark .abey-nav-tree__summary:hover,
.abey.abey--dark .abey-nav-tree__summary:focus {
  background: rgba(56, 189, 248, 0.08);
}

.abey-nav-link__ic {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 1.65rem;
  height: 1.65rem;
  flex-shrink: 0;
  font-size: 0.95rem;
  line-height: 1;
  border-radius: 0.45rem;
  background: rgba(37, 99, 235, 0.08);
  color: var(--abey-text);
}

/* Font Awesome dentro del ÔÇ£chipÔÇØ del sidebar */
.abey-nav-link__ic i {
  font-size: 0.82rem;
  line-height: 1;
}

.abey-nav-link--active .abey-nav-link__ic,
.abey-nav-link[aria-current="page"] .abey-nav-link__ic {
  background: rgba(37, 99, 235, 0.16);
  color: var(--abey-accent);
}

.abey-nav-link__txt {
  min-width: 0;
  flex: 1;
}

/* Sidebar ┬À ├írbol: en carriles estrechos permitir salto de l├¡nea (evita desbordes raros). */
.abey-sidebar .abey-nav-link--with-icon .abey-nav-link__txt,
.abey-sidebar .abey-nav-tree__summary-txt {
  overflow-wrap: anywhere;
  word-break: normal;
  hyphens: auto;
}

/* Sidebar: el chip del icono debe leerse antes que la etiqueta. */
.abey-sidebar .abey-nav-link--with-icon .abey-nav-link__txt {
  font-size: 0.835rem;
  font-weight: 450;
  color: color-mix(in srgb, var(--abey-text-muted) 94%, transparent);
  letter-spacing: 0.01em;
}

.abey-sidebar .abey-nav-link--with-icon .abey-nav-link__ic {
  width: 1.82rem;
  height: 1.82rem;
  font-size: 1.05rem;
  background: transparent;
}

.abey-sidebar .abey-nav-link--with-icon .abey-nav-link__ic i {
  font-size: 0.93rem;
}

.abey-sidebar .abey-nav-tree__summary-txt {
  font-size: 0.84rem;
  font-weight: 500;
  color: var(--abey-text-muted);
}

.abey-sidebar .abey-nav-tree__summary {
  font-weight: 550;
  color: var(--abey-text-muted);
}

.abey-sidebar .abey-nav-tree__summary-ic {
  width: 1.82rem;
  height: 1.82rem;
  font-size: 1.02rem;
  color: var(--abey-text);
  background: transparent;
}

.abey-sidebar .abey-nav-tree__summary-ic i {
  font-size: 0.9rem;
}

.abey.abey--dark .abey-sidebar .abey-nav-tree__summary-ic {
  background: transparent;
  color: color-mix(in srgb, var(--abey-accent) 45%, var(--abey-text));
}

.abey.abey--dark .abey-sidebar .abey-nav-link--with-icon:not(.abey-nav-link--active):not([aria-current="page"]) .abey-nav-link__ic {
  color: color-mix(in srgb, var(--abey-accent) 55%, var(--abey-text));
}

/* Sidebar: selecci├│n s├¡ conserva fondo en el chip (modo dashboard refuerza m├ís abajo). */
.abey-sidebar .abey-nav-link--with-icon.abey-nav-link--active .abey-nav-link__ic,
.abey-sidebar .abey-nav-link--with-icon[aria-current="page"] .abey-nav-link__ic {
  background: rgba(37, 99, 235, 0.16);
  color: var(--abey-accent);
}

.abey.abey--dark .abey-sidebar .abey-nav-link--with-icon.abey-nav-link--active .abey-nav-link__ic,
.abey.abey--dark .abey-sidebar .abey-nav-link--with-icon[aria-current="page"] .abey-nav-link__ic {
  background: color-mix(in srgb, var(--abey-accent) 28%, transparent);
  color: var(--abey-accent);
}

.abey-nav-link--with-icon.abey-nav-link--sidebar.abey-nav-link--active .abey-nav-link__txt,
.abey-nav-link--with-icon.abey-nav-link--sidebar[aria-current="page"] .abey-nav-link__txt {
  color: inherit;
  font-weight: 575;
}

.abey-sidebar .abey-nav-tree__summary:is(:hover, :focus) .abey-nav-tree__summary-txt,
.abey-sidebar details.abey-nav-tree[open]>.abey-nav-tree__summary .abey-nav-tree__summary-txt {
  color: color-mix(in srgb, var(--abey-text) 78%, var(--abey-text-muted));
}

.abey-nav-link--horizontal {
  color: var(--abey-text);
  font-size: 0.9rem;
  padding: 0.4rem 0.65rem;
}

.abey-nav-link:hover,
.abey-nav-link:focus {
  color: var(--abey-text);
  background: rgba(37, 99, 235, 0.08);
  outline: none;
}

.abey-nav-link--active,
.abey-nav-link[aria-current="page"] {
  color: var(--abey-accent);
  background: rgba(37, 99, 235, 0.1);
  border-color: rgba(37, 99, 235, 0.2);
}

.abey.abey--dark .abey-nav-link[aria-current="page"] {
  color: var(--abey-accent);
  background: rgba(56, 189, 248, 0.1);
  border-color: rgba(56, 189, 248, 0.25);
}

/* Contenido t├¡pico dentro del outlet (plantilla) */
.abey-starter-card {
  margin-top: 1rem;
  padding: 1rem 1.25rem;
  border: 1px solid var(--abey-border);
  border-radius: var(--abey-radius);
  background: var(--abey-surface);
  text-align: left;
  max-width: 32rem;
  box-shadow: var(--abey-shadow);
}

.abey-starter-card ul {
  margin: 0;
  padding-left: 1.1rem;
  color: var(--abey-text-muted);
  font-size: 0.9rem;
  line-height: 1.5;
}

.abey-starter-card li {
  margin-bottom: 0.35rem;
}

.abey-starter-card .abey-btn {
  margin-top: 0.75rem;
}

/* abey-button (UIKit) */
abey-button {
  display: inline-block;
}

abey-button>button.abey-btn {
  width: 100%;
}

.abey-starter-card__title {
  font-size: 0.95rem;
  font-weight: 600;
  margin: 0 0 0.5rem;
  color: var(--abey-text);
}

.abey-starter-footnote {
  font-size: 0.8rem;
  margin-top: 0.9rem;
  color: var(--abey-text-muted);
  max-width: 32rem;
  line-height: 1.45;
}

.abey-page-hero {
  max-width: 40rem;
  margin-bottom: 1.5rem;
}

.abey-page-hero h1,
.abey-outlet h1,
.abey-outlet--landing h1 {
  font-size: 1.4rem;
  font-weight: 700;
  margin: 0 0 0.5rem;
  color: var(--abey-text);
  letter-spacing: -0.02em;
}

.abey-outlet p,
.abey-outlet--landing p {
  color: var(--abey-text-muted);
  max-width: 40rem;
  line-height: 1.6;
  margin: 0 0 0.75rem;
}

/* P├írrafos dentro de vistas <abeyjs-view>: aprovechan el ancho del main, no 40rem */
.abey-outlet .abey-abeyview-page p,
.abey-outlet .abey-abeyview p,
.abey-outlet abeyjs-view p,
.abey-outlet .abey-abeyview-page .abey-abeyview-note {
  max-width: 100%;
}

/* Inicio: bienvenida tipo gu├¡a (hero + tarjetas "siguiente paso") */
.abey-welcome {
  width: 100%;
  max-width: 56rem;
  margin: 0 auto;
  padding: 0.35rem 0.15rem 1.75rem;
  box-sizing: border-box;
}

.abey-welcome__banner {
  border-radius: var(--abey-radius, 10px);
  padding: 1.75rem 1.5rem 1.65rem;
  background: linear-gradient(135deg, #5b21b6 0%, #4f46e5 50%, #4338ca 100%);
  color: #fff;
  box-shadow: 0 4px 24px rgba(79, 70, 229, 0.32);
  margin-bottom: 1.35rem;
}

.abey-welcome__kicker {
  display: block;
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(255, 255, 255, 0.82);
  margin-bottom: 0.4rem;
}

.abey-welcome__headline {
  font-size: 1.55rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: 1.2;
  margin: 0 0 0.45rem;
  color: #fff;
}

.abey-welcome__lead {
  font-size: 0.9rem;
  line-height: 1.5;
  margin: 0 0 0.8rem;
  color: rgba(255, 255, 255, 0.88);
  max-width: 38rem;
}

.abey-welcome__status {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-family: var(--abey-font-mono, ui-monospace, monospace);
  font-size: 0.8rem;
  font-weight: 500;
  padding: 0.4rem 0.65rem;
  border-radius: 6px;
  background: rgba(15, 23, 42, 0.2);
  color: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.abey-welcome__h2 {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--abey-text);
  margin: 0.25rem 0 0.6rem;
  letter-spacing: -0.02em;
}

.abey-welcome__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(11.5rem, 1fr));
  gap: 0.75rem;
}

a.abey-welcome-tile {
  display: block;
  padding: 0.95rem 1rem;
  border: 1px solid var(--abey-border, #e1e4e8);
  border-radius: var(--abey-radius, 10px);
  background: var(--abey-surface, #fff);
  text-decoration: none;
  color: var(--abey-text, #0f172a);
  box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
  transition: border-color 0.12s, box-shadow 0.12s, transform 0.12s;
  text-align: left;
}

a.abey-welcome-tile:hover,
a.abey-welcome-tile:focus {
  border-color: rgba(37, 99, 235, 0.4);
  box-shadow: 0 2px 12px rgba(37, 99, 235, 0.1);
  outline: none;
  transform: translateY(-1px);
}

.abey-welcome-tile__icon {
  display: block;
  font-size: 1.35rem;
  line-height: 1;
  margin-bottom: 0.3rem;
}

.abey-welcome-tile__icon i {
  font-size: 1.2rem;
  line-height: 1;
  color: #4f46e5;
}

.abey-welcome-tile__title {
  display: block;
  font-weight: 700;
  font-size: 0.9rem;
  line-height: 1.3;
  margin: 0 0 0.2rem;
}

.abey-welcome-tile__text {
  display: block;
  font-size: 0.78rem;
  line-height: 1.45;
  color: var(--abey-text-muted, #5c636d);
}

/* Tabla tipo dashboard (curso/listado) */
.abey-courses {
  width: 100%;
}

.abey-courses__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.85rem;
}

.abey-courses__head h1 {
  margin: 0;
  font-size: 1.02rem;
  font-weight: 700;
}

.abey-screen-toolbar {
  display: inline-flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem;
}

.abey-screen-toolbar__select-wrap,
.abey-screen-toolbar__search-wrap {
  display: inline-flex;
  align-items: center;
  gap: 0.38rem;
}

.abey-screen-toolbar__hint {
  color: var(--abey-text-muted);
  font-size: 0.72rem;
  font-weight: 600;
}

.abey-screen-toolbar__select,
.abey-screen-toolbar__search {
  border: 1px solid var(--abey-border);
  background: var(--abey-surface);
  color: var(--abey-text);
  border-radius: 8px;
  height: 1.95rem;
  padding: 0 0.55rem;
  font-size: 0.75rem;
  accent-color: var(--abey-accent);
}

.abey-screen-toolbar__search {
  min-width: 12rem;
}

.abey-courses__sort {
  color: var(--abey-text-muted);
  font-size: 0.78rem;
}

.abey-courses__table-wrap {
  background: var(--abey-surface);
  border: 1px solid var(--abey-border);
  border-radius: 12px;
  box-shadow: var(--abey-shadow);
  overflow-x: auto;
}

.abey-courses__table {
  width: 100%;
  border-collapse: collapse;
  min-width: 980px;
}

.abey-courses__table th,
.abey-courses__table td {
  text-align: left;
  border-bottom: 1px solid var(--abey-border);
  padding: 0.62rem 0.75rem;
  font-size: 0.8rem;
  vertical-align: middle;
}

.abey-courses__table thead th {
  color: var(--abey-text-muted);
  font-size: 0.72rem;
  font-weight: 700;
  white-space: nowrap;
}

.abey-courses__table tbody tr:hover {
  background: rgba(37, 99, 235, 0.04);
}

.abey-course-name {
  font-weight: 600;
  color: var(--abey-text);
  white-space: nowrap;
}

.abey-course-progress {
  width: 90px;
}

.abey-course-ring {
  --p: 0%;
  width: 1.8rem;
  height: 1.8rem;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.55rem;
  font-weight: 700;
  color: #0ea5a4;
  background: conic-gradient(#14b8a6 var(--p), #dbe4ea 0);
  position: relative;
}

.abey-course-ring::before {
  content: "";
  position: absolute;
  inset: 3px;
  border-radius: 999px;
  background: #fff;
}

.abey-course-ring {
  color: #0f172a;
}

.abey-course-ring__label {
  position: relative;
  z-index: 1;
  font-size: 0.52rem;
  font-weight: 700;
}

.abey-course-badge {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 0.18rem 0.56rem;
  font-size: 0.68rem;
  font-weight: 600;
  border: 1px solid transparent;
}

.abey-course-badge--ongoing {
  color: #0f766e;
  background: #ccfbf1;
  border-color: #99f6e4;
}

.abey-course-badge--done {
  color: #166534;
  background: #dcfce7;
  border-color: #bbf7d0;
}

.abey-course-badge--paused {
  color: #9a3412;
  background: #ffedd5;
  border-color: #fed7aa;
}

.abey-course-action {
  border: none;
  background: transparent;
  color: #0ea5a4;
  font-size: 0.72rem;
  font-weight: 700;
  cursor: pointer;
  padding: 0;
}

.abey-course-action:hover,
.abey-course-action:focus {
  color: #0891b2;
  text-decoration: underline;
  outline: none;
}

.abey-course-action--danger {
  color: #dc2626;
}

.abey-course-action--danger:hover,
.abey-course-action--danger:focus {
  color: #b91c1c;
}

.abey-course-actions {
  display: inline-flex;
  gap: 0.65rem;
  flex-wrap: wrap;
}

.abey-courses__foot {
  margin-top: 0.55rem;
  color: var(--abey-text-muted);
  font-size: 0.72rem;
}

/* <abeyjs-view> (HTML declarativo + {{ruta}} + abeyjs-for + abeyjs-html) */
/* Ritmo vertical unificado; misma familia que .abey-courses / .abey-list */
.abey-abeyview {
  --abey-abeyview-stack: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: var(--abey-abeyview-stack);
  width: 100%;
  max-width: 100%;
  min-width: 0;
}

.abey-abeyview-title {
  font-size: 1.2rem;
  font-weight: 800;
  margin: 0;
  color: var(--abey-text);
}

.abey-abeyview-block {
  margin: 0;
  padding: 0.9rem 1.15rem;
  border: 1px solid var(--abey-border);
  border-radius: var(--abey-radius, 10px);
  background: var(--abey-surface, #fff);
  box-shadow: 0 1px 2px rgba(15, 23, 42, 0.05);
}

.abey-abeyview-block p {
  margin: 0;
}

/* Nota con abeyjs-html: nodo p interno; reset estilo de agente de usuario */
.abey-abeyview-block.abey-html p {
  margin: 0;
}

.abey-abeyview-block.abey-html p+p {
  margin-top: 0.5rem;
}

.abey-abeyview-h2 {
  font-size: 1.05rem;
  font-weight: 700;
  margin: 0 0 0.5rem;
  color: var(--abey-text);
}

.abey-abeyview-p {
  margin: 0;
  font-size: 0.88rem;
  color: var(--abey-text-muted);
}

.abey-abeyview-sub {
  margin: 0;
  font-size: 0.88rem;
  color: var(--abey-text);
}

.abey-abeyview-sub .abey-abeyview-em {
  color: var(--abey-accent);
  font-style: normal;
  font-weight: 700;
}

.abey-abeyview-list {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  min-width: 0;
  margin: 0;
  padding: 0;
  border: none;
  background: none;
  box-shadow: none;
}

.abey-abeyview-list .abey-abeyview-h3 {
  margin: 0;
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--abey-text);
  letter-spacing: -0.02em;
}

.abey-abeyview-h3 {
  font-size: 0.95rem;
  font-weight: 700;
  margin: 0 0 0.4rem;
  color: var(--abey-text);
}

.abey-abeyview-table-wrap {
  overflow-x: auto;
  border: 1px solid var(--abey-border);
  border-radius: 12px;
  background: var(--abey-surface);
  box-shadow: 0 1px 2px rgba(15, 23, 42, 0.05), 0 6px 28px -8px rgba(15, 23, 42, 0.12);
  margin: 0;
}

.abey-abeyview-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 0;
  font-size: 0.8125rem;
}

.abey-abeyview-table th,
.abey-abeyview-table td {
  text-align: left;
  border-bottom: 1px solid var(--abey-border);
  padding: 0.72rem 1rem;
  font-size: 0.8125rem;
  vertical-align: middle;
  transition: background 0.12s ease, box-shadow 0.12s ease;
}

.abey-abeyview-table thead th {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--abey-text-muted);
  background: linear-gradient(180deg, var(--abey-surface-elev, #fcfcfd) 0%, #f1f5f9 100%);
  border-bottom: 2px solid var(--abey-border-strong, var(--abey-border));
  white-space: nowrap;
  padding-top: 0.8rem;
  padding-bottom: 0.8rem;
}

.abey-abeyview-table tbody tr:nth-child(odd) td {
  background: rgba(248, 250, 252, 0.9);
}

.abey-abeyview-table tbody tr:hover td {
  background: rgba(99, 102, 241, 0.09);
  box-shadow: inset 0 0 0 1px rgba(99, 102, 241, 0.12);
}

.abey-abeyview-table tbody tr:last-child td {
  border-bottom: none;
}

.abey-abeyview-td-nombre {
  font-weight: 600;
  color: var(--abey-text);
  white-space: nowrap;
}

.abey-abeyview-td-cursos {
  color: var(--abey-text-muted);
  font-size: 0.8rem;
}

/* Contenedor: vista + pie (misma pila que .abey-abeyview) */
.abey-abeyview-page {
  display: flex;
  flex-direction: column;
  gap: var(--abey-abeyview-stack, 1.25rem);
  width: 100%;
  max-width: 100%;
  min-width: 0;
  padding: 0 0 0.5rem;
  box-sizing: border-box;
}

.abey-abeyview-page>.abey-abeyview-note {
  margin: 0;
}

.abey-abeyview-note {
  font-size: 0.75rem;
  color: var(--abey-text-muted);
  line-height: 1.4;
  max-width: 100%;
  margin: 0;
  padding: 0;
}

.abey-abeyview-note code {
  font-size: 0.95em;
  font-family: ui-monospace, "Cascadia Code", monospace;
  padding: 0.1em 0.35em;
  border-radius: 4px;
  background: var(--abey-surface);
  color: var(--abey-text);
  border: 1px solid var(--abey-border);
}

.abey.abey--dark .abey-abeyview .abey-abeyview-table tbody tr:nth-child(odd) td {
  background: rgba(15, 23, 42, 0.45);
}

.abey.abey--dark .abey-abeyview .abey-abeyview-table tbody tr:hover td {
  background: rgba(56, 189, 248, 0.12) !important;
  box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.2);
}

.abey.abey--dark .abey-abeyview .abey-abeyview-table thead th {
  background: linear-gradient(180deg, #1a2234 0%, #151b2a 100%);
  border-bottom-color: var(--abey-border-strong, var(--abey-border));
}

/* Ruta 404 (mountRoutedApp) */
.abey-routed-miss {
  color: var(--abey-error);
  font-weight: 500;
  padding: 0.5rem 0;
}

/* Landing: hero ancho */
.abey-shell--landing .abey-outlet--landing {
  background: linear-gradient(180deg, var(--abey-surface) 0%, var(--abey-bg) 36%);
  border-bottom: 1px solid var(--abey-border);
  padding: 2.5rem 1.5rem 3.5rem;
  text-align: center;
}

.abey-landing-hero,
.abey-landing-sect {
  max-width: 44rem;
  margin-left: auto;
  margin-right: auto;
  text-align: center;
}

.abey-landing-hero h1,
.abey-landing-sect h1 {
  font-size: 1.85rem;
  font-weight: 800;
  line-height: 1.2;
  margin: 0 0 0.75rem;
  background: linear-gradient(180deg, var(--abey-text) 0%, var(--abey-text-muted) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.abey-landing-hero__lead,
.abey-landing-sect p {
  color: var(--abey-text-muted);
  font-size: 0.95rem;
  line-height: 1.6;
  margin: 0;
}

@media (min-width: 901px) {
  .abey-shell__body>.abey-sidebar {
    position: sticky;
    top: var(--abey-appbar-h);
    align-self: flex-start;
    max-height: calc(100vh - var(--abey-appbar-h));
    box-sizing: border-box;
    z-index: 2;
  }
}

/*
 * Shell admin ┬À horizontal: una sola franja (**`abey-appbar__row`**) con cromado sobrio Omega.
 */
.abey-shell[data-abey-nav-mode="horizontal"].abey-shell--dashboard .abey-appbar--dashboard {
  overflow: visible;
  background: var(--abey-surface);
  border-bottom: 1px solid var(--abey-border);
  box-shadow: 0 1px 0 rgba(15, 23, 42, 0.04);
}

.abey.abey--dark .abey-shell[data-abey-nav-mode="horizontal"].abey-shell--dashboard .abey-appbar--dashboard {
  background: var(--abey-surface);
  border-bottom-color: color-mix(in srgb, var(--abey-border) 88%, transparent);
  box-shadow: 0 1px 0 rgba(0, 0, 0, 0.35);
}

.abey-shell[data-abey-nav-mode="horizontal"].abey-shell--dashboard .abey-appbar--dashboard .abey-appbar__inner {
  overflow: visible;
  align-items: center;
  padding-inline: clamp(0.875rem, 2.2vw, 1.5rem);
}

.abey-shell[data-abey-nav-mode="horizontal"].abey-shell--dashboard .abey-appbar__row {
  align-items: center;
}

/* App bar (+ men├║s desplegables) por encima del outlet; overflow visible en cadena para no recortar el panel. */
.abey-shell[data-abey-nav-mode="horizontal"]>.abey-appbar {
  position: sticky;
  z-index: 50;
}

.abey-shell[data-abey-nav-mode="horizontal"] .abey-shell__body {
  position: relative;
  z-index: 0;
}

/* Marca: bloque proporcional sin ÔÇ£jewelÔÇØ; acento contenido tokens Abey */
.abey-shell[data-abey-nav-mode="horizontal"].abey-shell--dashboard .abey-appbar__mark {
  flex: 0 0 auto;
  width: auto;
  max-width: none;
  min-width: 0;
  display: grid;
  grid-template-columns: auto minmax(0, max-content);
  column-gap: 0.55rem;
  row-gap: 0;
  align-items: start;
  justify-items: start;
  text-align: left;
  align-self: center;
  padding: 0.35rem 0.85rem 0.35rem 0;
  margin: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.abey-shell[data-abey-nav-mode="horizontal"].abey-shell--dashboard .abey-appbar__mark::before {
  content: "";
  grid-column: 1;
  grid-row: 1 / -1;
  justify-self: center;
  align-self: center;
  width: 1.85rem;
  height: 1.85rem;
  border-radius: 0.5rem;
  background: linear-gradient(150deg,
      color-mix(in srgb, var(--abey-accent, #6366f1) 94%, transparent) 0%,
      color-mix(in srgb, var(--abey-accent) 58%, var(--abey-text)) 100%);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 1px 3px rgba(15, 23, 42, 0.1);
}

.abey.abey--dark .abey-shell[data-abey-nav-mode="horizontal"].abey-shell--dashboard .abey-appbar__mark::before {
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06), 0 0 0 1px rgba(255, 255, 255, 0.06);
}

.abey-shell[data-abey-nav-mode="horizontal"].abey-shell--dashboard .abey-appbar__mark-text {
  grid-column: 2;
  grid-row: 1 / -1;
  align-self: center;
}

.abey-shell[data-abey-nav-mode="horizontal"].abey-shell--dashboard .abey-appbar__mark-logo {
  grid-column: 1;
  grid-row: 1 / -1;
  justify-self: center;
  align-self: center;
  height: 1.85rem;
  width: auto;
  max-height: none;
  max-width: min(11rem, 36vw);
}

.abey-shell[data-abey-nav-mode="horizontal"].abey-shell--dashboard .abey-appbar__mark-text>.abey-appbar__mark-title:only-child {
  font-weight: 700;
  font-size: 1rem;
  letter-spacing: -0.024em;
  text-transform: none;
  color: var(--abey-text);
  line-height: 1.2;
}

.abey-shell[data-abey-nav-mode="horizontal"].abey-shell--dashboard .abey-appbar__mark-heading .abey-appbar__mark-title {
  font-weight: 775;
  font-size: 1rem;
  letter-spacing: -0.024em;
  text-transform: none;
  line-height: 1.2;
}

.abey-shell[data-abey-nav-mode="horizontal"].abey-shell--dashboard .abey-appbar__mark-title--lead {
  color: var(--abey-brand-mark-lead, var(--abey-text));
}

.abey-shell[data-abey-nav-mode="horizontal"].abey-shell--dashboard .abey-appbar__mark-sub {
  margin-top: 1px;
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 0.02em;
  text-transform: none;
  color: var(--abey-text-muted);
}

.abey-shell[data-abey-nav-mode="horizontal"] .abey-appbar__row .abey-shell__nav-horizontal {
  flex: 1 1 auto;
  min-width: 0;
  display: flex;
  flex-flow: row nowrap;
  align-items: center;
  justify-content: flex-start;
  gap: 0.0625rem;
  padding: 0 0.35rem;
  /*
   * Important: omit overflow:auto on axes here. With overflow-x: auto + overflow-y: visible,
   * CSS clamps overflow-y to auto and clips absolutely positioned submenu panels (ÔÇ£no flotaÔÇØ).
   * Si necesitamos scroll horizontal con much├¡simos ├¡tems de nivel 1, conviene una fila scroll
   * interna y portar los paneles (p.ej. popover) fuera del scrollport ÔÇö no el nav entero con auto.
   */
  overflow: visible;
  border: none;
  margin: 0;
  background: transparent;
  box-shadow: none;
  position: relative;
  z-index: 0;
}

.abey-shell__nav-horizontal>.abey-nav-link--horizontal {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  border-radius: 0.4rem;
  border: 1px solid transparent;
  font-size: 0.8125rem;
  font-weight: 550;
  padding: 0.34rem 0.62rem;
  color: color-mix(in srgb, var(--abey-text) 94%, var(--abey-text-muted));
  transition: background 0.12s ease, color 0.12s ease, border-color 0.12s ease;
}

.abey-shell__nav-horizontal>.abey-nav-link--horizontal:hover,
.abey-shell__nav-horizontal>.abey-nav-link--horizontal:focus-visible {
  background: rgba(15, 23, 42, 0.05);
  outline: none;
}

.abey.abey--dark .abey-shell__nav-horizontal>.abey-nav-link--horizontal:hover,
.abey.abey--dark .abey-shell__nav-horizontal>.abey-nav-link--horizontal:focus-visible {
  background: rgba(255, 255, 255, 0.065);
}

.abey-shell__nav-horizontal>.abey-nav-link--horizontal.abey-nav-link--active,
.abey-shell__nav-horizontal>.abey-nav-link--horizontal[aria-current="page"] {
  color: var(--abey-accent, #2563eb);
  background: color-mix(in srgb, var(--abey-accent) 11%, transparent);
  border-color: color-mix(in srgb, var(--abey-accent) 26%, transparent);
  box-shadow: none;
}

.abey.abey--dark .abey-shell__nav-horizontal>.abey-nav-link--horizontal.abey-nav-link--active,
.abey.abey--dark .abey-shell__nav-horizontal>.abey-nav-link--horizontal[aria-current="page"] {
  color: color-mix(in srgb, var(--abey-accent) 90%, #fff);
  background: color-mix(in srgb, var(--abey-accent) 14%, transparent);
  border-color: color-mix(in srgb, var(--abey-accent) 30%, transparent);
}

.abey-shell__nav-horizontal>.abey-nav-link--horizontal.abey-nav-link--with-icon .abey-nav-link__ic {
  width: 1.5rem;
  height: 1.5rem;
  font-size: 0.9rem;
}

.abey-shell__nav-horizontal>.abey-nav-link--horizontal.abey-nav-link--with-icon .abey-nav-link__txt {
  font-weight: inherit;
  font-size: inherit;
}

.abey-shell__nav-horizontal .abey-nav-hz {
  position: relative;
  display: block;
}

.abey-shell__nav-horizontal>.abey-nav-hz[open] {
  z-index: 160;
}

.abey-shell__nav-horizontal .abey-nav-hz__panel .abey-nav-hz[open] {
  z-index: 161;
}

.abey-shell__nav-horizontal>.abey-nav-hz>.abey-nav-hz__summary {
  list-style: none;
  cursor: pointer;
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 0.34rem;
  border-radius: 0.4rem;
  border: 1px solid transparent;
  font-size: 0.8125rem;
  font-weight: 550;
  padding: 0.34rem 1.6rem 0.34rem 0.62rem;
  color: color-mix(in srgb, var(--abey-text) 94%, var(--abey-text-muted));
  transition: background 0.12s ease, border-color 0.12s ease, color 0.12s ease;
}

.abey-shell__nav-horizontal>.abey-nav-hz>.abey-nav-hz__summary::-webkit-details-marker {
  display: none;
}

.abey-shell__nav-horizontal>.abey-nav-hz>.abey-nav-hz__summary::marker {
  content: "";
}

.abey-shell__nav-horizontal>.abey-nav-hz>.abey-nav-hz__summary::after {
  content: "";
  pointer-events: none;
  position: absolute;
  right: 0.62rem;
  top: 50%;
  margin-top: -2px;
  width: 0.38rem;
  height: 0.38rem;
  border-right: 2px solid currentColor;
  border-bottom: 2px solid currentColor;
  transform: translateY(-50%) rotate(45deg);
  opacity: 0.72;
}

.abey-shell__nav-horizontal>.abey-nav-hz[open]>.abey-nav-hz__summary::after {
  transform: translateY(-20%) rotate(225deg);
}

.abey-shell__nav-horizontal>.abey-nav-hz:hover>.abey-nav-hz__summary,
.abey-shell__nav-horizontal>.abey-nav-hz>.abey-nav-hz__summary:focus-visible {
  background: rgba(15, 23, 42, 0.05);
  outline: none;
}

.abey-shell__nav-horizontal>.abey-nav-hz--branch-active>.abey-nav-hz__summary {
  color: var(--abey-accent, #2563eb);
  background: color-mix(in srgb, var(--abey-accent) 11%, transparent);
  border-color: color-mix(in srgb, var(--abey-accent) 26%, transparent);
  box-shadow: none;
}

.abey.abey--dark .abey-shell__nav-horizontal>.abey-nav-hz:hover>.abey-nav-hz__summary,
.abey.abey--dark .abey-shell__nav-horizontal>.abey-nav-hz>.abey-nav-hz__summary:focus-visible {
  background: rgba(255, 255, 255, 0.065);
}

.abey.abey--dark .abey-shell__nav-horizontal>.abey-nav-hz--branch-active>.abey-nav-hz__summary {
  color: color-mix(in srgb, var(--abey-accent) 90%, #fff);
  background: color-mix(in srgb, var(--abey-accent) 14%, transparent);
  border-color: color-mix(in srgb, var(--abey-accent) 30%, transparent);
}

.abey-nav-hz__ic {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 1.34rem;
  height: 1.34rem;
  flex-shrink: 0;
  font-size: 0.92rem;
  line-height: 1;
}

.abey-nav-hz__ic i {
  font-size: inherit;
}

.abey-nav-hz__txt {
  min-width: 0;
}

/* S├│lo el grupo ra├¡z (**Gu├¡as**) en barra horizontal: ellipsis si la etiqueta no cabe. */
.abey-shell__nav-horizontal > .abey-nav-hz > .abey-nav-hz__summary .abey-nav-hz__txt {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: min(40vw, 12.5rem);
}

.abey-shell__nav-horizontal .abey-nav-hz__panel {
  position: absolute;
  left: 0;
  top: calc(100% + 6px);
  min-width: 11.75rem;
  max-width: min(24rem, min(92vw, 100% - 1rem));
  padding: 0.3rem;
  border-radius: var(--abey-radius-sm);
  border: 1px solid var(--abey-border);
  background: var(--abey-surface-elev);
  box-shadow: 0 8px 28px rgba(15, 23, 42, 0.1), 0 2px 6px rgba(15, 23, 42, 0.04);
  z-index: 200;
  overflow-x: hidden;
  box-sizing: border-box;
}

.abey.abey--dark .abey-shell__nav-horizontal .abey-nav-hz__panel {
  box-shadow:
    0 12px 36px rgba(0, 0, 0, 0.4),
    0 0 0 1px color-mix(in srgb, var(--abey-border) 70%, transparent);
}

.abey-shell__nav-horizontal .abey-nav-hz__panel a.abey-nav-link--hz-drop {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 0.52rem;
  width: 100%;
  padding: 0.44rem 0.62rem;
  border-radius: 0.52rem;
  font-size: 0.835rem;
  font-weight: 550;
  box-sizing: border-box;
  min-width: 0;
}

.abey-shell__nav-horizontal .abey-nav-hz__panel a.abey-nav-link--hz-drop .abey-nav-link__ic {
  margin-top: 0.06em;
  flex-shrink: 0;
}

.abey-shell__nav-horizontal .abey-nav-hz__panel a.abey-nav-link--hz-drop .abey-nav-link__txt {
  min-width: 0;
  flex: 1;
  align-self: center;
  white-space: normal;
  overflow-wrap: anywhere;
  word-break: normal;
  line-height: 1.28;
  hyphens: auto;
}

.abey-shell__nav-horizontal .abey-nav-hz__panel .abey-nav-hz__txt {
  white-space: normal;
  overflow-wrap: anywhere;
  line-height: 1.25;
  overflow: visible;
  max-width: none;
  text-overflow: clip;
}

.abey-shell__nav-horizontal .abey-nav-hz__panel > .abey-nav-hz .abey-nav-hz__summary {
  padding: 0.4rem 0.55rem;
  font-size: 0.8rem;
  align-items: flex-start;
}

.abey-shell__nav-horizontal .abey-nav-hz__panel .abey-nav-hz__panel {
  left: 0;
  top: calc(100% + 4px);
}

/*
 * Overlay / drawer ┬À capa clic para cerrar (por debajo del aside; escritorio Ôåæ z-index para quedar sobre el contenido).
 */
button.abey-shell__nav-scrim {
  appearance: none;
  -webkit-appearance: none;
  position: fixed;
  inset: var(--abey-appbar-h) 0 0 0;
  z-index: 7;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 0;
  cursor: pointer;
  background: rgba(15, 23, 42, 0.45);
  backdrop-filter: blur(4px) saturate(1.08);
  -webkit-backdrop-filter: blur(4px) saturate(1.08);
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 0.22s ease, visibility 0.22s;
}

.abey-shell__nav-scrim:focus {
  outline: none;
}

.abey-shell__nav-scrim:focus-visible {
  outline: 3px solid var(--abey-accent);
  outline-offset: -3px;
}

button.abey-shell__nav-scrim[data-abey-active="true"] {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

.abey.abey--dark button.abey-shell__nav-scrim {
  background: rgba(3, 7, 18, 0.62);
}

@media (min-width: 901px) {
  button.abey-shell__nav-scrim[data-abey-active="true"] {
    z-index: 14;
  }
}

@media (prefers-reduced-motion: reduce) {
  button.abey-shell__nav-scrim {
    transition-duration: 0.01ms !important;
  }
}

@media (min-width: 901px) {
  .abey-shell[data-abey-nav-mode="compact"] {
    --abey-sidebar-w: 13.25rem;
  }

  .abey-shell[data-abey-nav-mode="compact"] .abey-shell__body>.abey-sidebar .abey-sidebar__inner {
    padding-bottom: 0.85rem;
  }

  .abey-shell[data-abey-nav-mode="compact"] .abey-shell__body>.abey-sidebar .abey-nav-link--sidebar:not(.abey-nav-link--horizontal) {
    font-size: 0.82rem;
    padding: 0.38rem 0.55rem;
  }

  .abey-shell[data-abey-nav-mode="compact"] .abey-shell__body>.abey-sidebar .abey-nav-tree__summary {
    font-size: 0.82rem;
    padding: 0.4rem 0.55rem;
  }

  .abey-shell[data-abey-nav-mode="compact"] .abey-appbar--dashboard .abey-appbar__mark {
    flex-basis: var(--abey-sidebar-w);
    width: var(--abey-sidebar-w);
    max-width: var(--abey-sidebar-w);
  }

  /*
   * Slim colapsado: rail tipo Prime ÔÇö icono arriba, etiqueta peque├▒a debajo (texto visible).
   * Expandido (hover / foco / open): mismo ancho est├índar ÔÇö filas horizontales.
   */
  .abey-shell[data-abey-nav-mode="slim"] {
    --abey-slim-rail-w: 5.85rem;
  }

  /* Rail estrecha; expande con hover, foco en navegaci├│n o Ôÿ░ (m├│vil / si el toggle es visible). */
  .abey-shell[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar {
    flex: 0 0 var(--abey-slim-rail-w);
    width: var(--abey-slim-rail-w);
    max-width: var(--abey-slim-rail-w);
    overflow: visible;
    transition:
      flex-basis 0.26s cubic-bezier(0.32, 0.72, 0.25, 1),
      width 0.26s cubic-bezier(0.32, 0.72, 0.25, 1),
      max-width 0.26s cubic-bezier(0.32, 0.72, 0.25, 1),
      box-shadow 0.26s ease;
  }

  .abey-shell[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:is(:hover, :focus-within, [data-abey-open="true"]) {
    flex-basis: var(--abey-sidebar-w);
    width: var(--abey-sidebar-w);
    max-width: var(--abey-sidebar-w);
    box-shadow: 8px 0 36px rgba(15, 23, 42, 0.1);
    z-index: 6;
  }

  .abey.abey--dark .abey-shell[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:is(:hover, :focus-within, [data-abey-open="true"]) {
    box-shadow: 10px 0 40px rgba(0, 0, 0, 0.45);
  }

  .abey-shell[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-sidebar__inner {
    overflow-x: hidden;
    overflow-y: auto;
    scrollbar-gutter: stable;
    padding-left: 0.32rem;
    padding-right: 0.4rem;
  }

  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-sidebar__inner {
    padding-left: 0.28rem;
    padding-right: 0.38rem;
  }

  .abey-shell[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-stack {
    align-items: center;
    width: 100%;
  }

  .abey-shell[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-link--sidebar:hover,
  .abey-shell[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-link--sidebar:focus-visible {
    transform: none;
  }

  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-link--sidebar:not(.abey-nav-link--horizontal),
  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-tree__summary {
    padding: 0.45rem 0.22rem;
  }

  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-link[aria-current="page"].abey-nav-link--sidebar::before,
  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-link--active.abey-nav-link--sidebar::before {
    display: none;
  }

  .abey-shell[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-link--with-icon.abey-nav-link--sidebar {
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    gap: 0.3rem;
    text-align: center;
    border-radius: 0.65rem;
  }

  /* Etiquetas bajo el icono ÔÇö visibles en carril angosto */
  .abey-shell[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-link--with-icon.abey-nav-link--sidebar .abey-nav-link__txt {
    flex: none;
    width: 100%;
    min-width: 0;
    max-width: 100%;
    margin: 0;
    overflow: hidden;
    text-align: center;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.015em;
    line-height: 1.18;
    white-space: normal;
    word-break: break-word;
    hyphens: auto;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    color: color-mix(in srgb, var(--abey-text-muted) 88%, transparent);
    transition: none;
  }

  .abey-shell[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-link--with-icon.abey-nav-link--sidebar.abey-nav-link--active .abey-nav-link__txt,
  .abey-shell[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-link--with-icon.abey-nav-link--sidebar[aria-current="page"] .abey-nav-link__txt {
    color: color-mix(in srgb, var(--abey-accent, #2563eb) 55%, var(--abey-text));
  }

  .abey-shell[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-tree__summary {
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    gap: 0.3rem;
    text-align: center;
    padding: 0.45rem 0.22rem;
    border-radius: 0.65rem;
  }

  .abey-shell[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-tree__summary-txt {
    flex: none;
    width: 100%;
    min-width: 0;
    overflow: hidden;
    text-align: center;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.015em;
    line-height: 1.18;
    white-space: normal;
    word-break: break-word;
    hyphens: auto;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-clamp: 3;
  }

  /* En carril: sin sub├írbol hasta expandir lateral (coincide con hover / foco sobre men├║ amplio). */
  .abey-shell[data-abey-nav-mode="slim"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-tree__subs {
    display: none;
  }

  .abey-shell[data-abey-nav-mode="slim"] .abey-appbar--dashboard .abey-appbar__mark {
    flex-basis: var(--abey-slim-rail-w);
    width: var(--abey-slim-rail-w);
    max-width: var(--abey-slim-rail-w);
    transition: flex-basis 0.26s cubic-bezier(0.32, 0.72, 0.25, 1), width 0.26s cubic-bezier(0.32, 0.72, 0.25, 1),
      max-width 0.26s cubic-bezier(0.32, 0.72, 0.25, 1);
  }

  .abey-shell[data-abey-nav-mode="slim"]:has(.abey-shell__body > .abey-sidebar:is(:hover, :focus-within, [data-abey-open="true"])) .abey-appbar--dashboard .abey-appbar__mark {
    flex-basis: var(--abey-sidebar-w);
    width: var(--abey-sidebar-w);
    max-width: var(--abey-sidebar-w);
  }

  /*
   * Franja lateral izquierda (toggle): antes `translateX(calc(-100% + ÔÇª))` dejaba visible
   * el borde derecho del aside ÔÇö el Ôÿ░ est├í a la izquierda ÔåÆ el men├║ se ve├¡a cortado mal.
   */
  .abey-shell[data-abey-nav-mode="reveal"] {
    /* Chip + paddings dashboard; menos de ~5rem recorta iconos contra el borde. */
    --abey-overlay-rail-w: 5.5rem;
  }

  /* Reveal: rail estrecho; Ôÿ░ (`data-abey-open`), hover o foco dentro ampl├¡an el ancho (t├íctil/teclado). */
  .abey-shell[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar {
    position: fixed;
    left: 0;
    top: var(--abey-appbar-h);
    height: calc(100vh - var(--abey-appbar-h));
    max-height: none;
    align-self: auto;
    z-index: 18;
    width: var(--abey-overlay-rail-w);
    min-width: var(--abey-overlay-rail-w);
    max-width: var(--abey-overlay-rail-w);
    flex: 0 0 auto;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
    visibility: visible;
    transform: none;
    transition:
      width 0.28s cubic-bezier(0.32, 0.72, 0.25, 1),
      min-width 0.28s cubic-bezier(0.32, 0.72, 0.25, 1),
      max-width 0.28s cubic-bezier(0.32, 0.72, 0.25, 1),
      box-shadow 0.28s ease;
    box-shadow: 4px 0 24px rgba(15, 23, 42, 0.08);
  }

  .abey-shell[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:is(:hover, :focus-within, [data-abey-open="true"]) {
    width: min(18rem, calc(100vw - 12px));
    min-width: min(18rem, calc(100vw - 12px));
    max-width: min(18rem, calc(100vw - 12px));
    overflow: visible;
    box-shadow: 12px 0 48px rgba(15, 23, 42, 0.18);
  }

  .abey.abey--dark .abey-shell[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:is(:hover, :focus-within, [data-abey-open="true"]) {
    box-shadow: 16px 0 56px rgba(0, 0, 0, 0.45);
  }

  .abey-shell[data-abey-nav-mode="reveal"] .abey-sidebar__nav {
    flex: 1;
    min-height: 0;
  }

  .abey-shell[data-abey-nav-mode="reveal"] .abey-sidebar__inner {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
  }

  /* Reveal escritorio: sin Ôÿ░ en el rail (solo iconos); ampliaci├│n con hover o foco en la lista. El Ôÿ░ sigue en m├│vil Ôëñ900px. */
  .abey-shell[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar .abey-sidebar__toggle {
    display: none !important;
  }

  /* Reveal colapsado: texto como slim (iconos en carril estrecho). */
  .abey-shell[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-link__txt {
    opacity: 0;
    visibility: hidden;
    width: 0;
    min-width: 0;
    max-width: 0;
    margin: 0;
    overflow: hidden;
    white-space: nowrap;
    transition: opacity 0.15s ease, visibility 0.15s ease, width 0.2s ease;
  }

  .abey-shell[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-tree__summary-txt {
    opacity: 0;
    visibility: hidden;
    width: 0;
    min-width: 0;
    max-width: 0;
    overflow: hidden;
    white-space: nowrap;
    flex: unset;
    transition: opacity 0.15s ease, visibility 0.15s ease, width 0.2s ease;
  }

  .abey-shell[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-tree__subs {
    display: none;
  }

  .abey-shell[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-link--with-icon.abey-nav-link--sidebar {
    justify-content: center;
    gap: 0;
  }

  .abey-shell[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-tree__summary {
    justify-content: center;
    gap: 0;
  }

  /* Overlay / drawer: cerrado fuera del lienzo (Ôÿ░ en la app bar); abierto mismo panel que en m├│vil. */
  .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar,
  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar {
    position: fixed;
    left: 0;
    top: var(--abey-appbar-h);
    height: calc(100vh - var(--abey-appbar-h));
    max-height: none;
    align-self: auto;
    z-index: 18;
    flex: 0 0 auto;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
    width: min(18rem, calc(100vw - 12px));
    min-width: min(18rem, calc(100vw - 12px));
    max-width: min(18rem, calc(100vw - 12px));
    transition:
      transform 0.26s cubic-bezier(0.32, 0.72, 0.25, 1),
      box-shadow 0.26s ease;
    border-right: none;
    background: linear-gradient(180deg, var(--abey-surface) 0%, color-mix(in srgb, var(--abey-surface) 93%, var(--abey-accent) 3%) 100%);
  }

  .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]),
  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) {
    transform: translateX(-100%);
    pointer-events: none;
    box-shadow: none;
  }

  .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar[data-abey-open="true"],
  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar[data-abey-open="true"] {
    transform: translateX(0);
    pointer-events: auto;
    overflow: hidden;
    border-right: 2px solid color-mix(in srgb, var(--abey-accent) 35%, var(--abey-border));
    box-shadow:
      12px 0 48px rgba(15, 23, 42, 0.2),
      0 0 0 1px color-mix(in srgb, var(--abey-border) 70%, transparent);
  }

  .abey.abey--dark .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar[data-abey-open="true"],
  .abey.abey--dark .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar[data-abey-open="true"] {
    box-shadow:
      16px 0 52px rgba(0, 0, 0, 0.48),
      0 0 0 1px color-mix(in srgb, var(--abey-accent) 18%, transparent);
  }

  .abey-shell[data-abey-nav-mode="overlay"] .abey-sidebar__toggle,
  .abey-shell[data-abey-nav-mode="drawer"] .abey-sidebar__toggle {
    display: inline-flex;
    align-self: center;
    flex-shrink: 0;
    margin-left: auto;
    margin-right: auto;
  }

  .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-sidebar__toggle,
  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-sidebar__toggle {
    margin-top: 0.75rem;
    width: 2.5rem;
    height: 2.5rem;
    font-size: 1.22rem;
    line-height: 1;
    font-weight: 600;
    border-radius: calc(var(--abey-radius-sm) + 2px);
    border: 2px solid color-mix(in srgb, var(--abey-accent) 48%, var(--abey-border));
    background: linear-gradient(165deg,
        color-mix(in srgb, var(--abey-accent) 18%, var(--abey-surface)) 0%,
        color-mix(in srgb, var(--abey-surface) 96%, var(--abey-accent)) 100%);
    color: var(--abey-accent-hover, var(--abey-accent));
    box-shadow:
      0 2px 8px rgba(15, 23, 42, 0.12),
      0 1px 0 rgba(255, 255, 255, 0.35) inset;
  }

  .abey.abey--dark .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-sidebar__toggle,
  .abey.abey--dark .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-sidebar__toggle {
    background: linear-gradient(165deg,
        color-mix(in srgb, var(--abey-accent) 22%, var(--abey-surface)) 0%,
        color-mix(in srgb, var(--abey-surface) 94%, transparent) 100%);
    color: var(--abey-accent);
    box-shadow:
      0 2px 14px rgba(0, 0, 0, 0.4),
      0 0 18px color-mix(in srgb, var(--abey-accent) 22%, transparent);
  }

  .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar[data-abey-open="true"] .abey-sidebar__toggle,
  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar[data-abey-open="true"] .abey-sidebar__toggle {
    margin-top: 0.35rem;
  }

  .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar .abey-sidebar__nav,
  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar .abey-sidebar__nav {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar .abey-sidebar__inner,
  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar .abey-sidebar__inner {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
  }

  /* Colapsado overlay/drawer: paddings sim├®tricos + ├¡tems centrados (evita chips cortados a la izquierda). */
  .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-sidebar__inner,
  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-sidebar__inner {
    padding-left: 0.3rem;
    padding-right: 0.42rem;
    padding-top: 0.2rem;
    box-sizing: border-box;
  }

  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-sidebar__inner,
  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-sidebar__inner {
    padding-left: 0.26rem;
    padding-right: 0.36rem;
  }

  .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-stack,
  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-stack {
    align-items: center;
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
  }

  .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-link--with-icon.abey-nav-link--sidebar,
  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-link--with-icon.abey-nav-link--sidebar {
    justify-content: center;
    gap: 0;
  }

  .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-tree__summary,
  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-tree__summary {
    justify-content: center;
    gap: 0;
  }

  .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-link--sidebar:not(.abey-nav-link--horizontal),
  .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-tree__summary,
  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-link--sidebar:not(.abey-nav-link--horizontal),
  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-tree__summary {
    padding-left: 0.32rem;
    padding-right: 0.32rem;
  }

  /* Dashboard usa paddings algo mayores por defecto: un poco m├ís apretados en rail. */
  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-link--sidebar:not(.abey-nav-link--horizontal),
  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-tree__summary,
  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-link--sidebar:not(.abey-nav-link--horizontal),
  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-tree__summary {
    padding-left: 0.26rem;
    padding-right: 0.26rem;
  }

  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-link--sidebar:hover,
  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-link--sidebar:focus-visible,
  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-link--sidebar:hover,
  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-link--sidebar:focus-visible {
    transform: none;
  }

  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-link[aria-current="page"].abey-nav-link--sidebar::before,
  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-link--active.abey-nav-link--sidebar::before,
  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-link[aria-current="page"].abey-nav-link--sidebar::before,
  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar:not([data-abey-open="true"]) .abey-nav-link--active.abey-nav-link--sidebar::before {
    left: 3px;
    width: 2px;
  }

  /* Reveal (rail colapsado): mismos m├írgenes que overlay carril. */
  .abey-shell[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-sidebar__inner {
    padding-left: 0.3rem;
    padding-right: 0.42rem;
    box-sizing: border-box;
  }

  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-sidebar__inner {
    padding-left: 0.26rem;
    padding-right: 0.36rem;
  }

  .abey-shell[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-stack {
    align-items: center;
    width: 100%;
    min-width: 0;
  }

  .abey-shell[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-link--sidebar:not(.abey-nav-link--horizontal),
  .abey-shell[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-tree__summary {
    padding-left: 0.32rem;
    padding-right: 0.32rem;
  }

  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-link--sidebar:not(.abey-nav-link--horizontal),
  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-tree__summary {
    padding-left: 0.26rem;
    padding-right: 0.26rem;
  }

  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-link--sidebar:hover,
  .abey-shell.abey-shell--dashboard[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar:not(:hover):not(:focus-within):not([data-abey-open="true"]) .abey-nav-link--sidebar:focus-visible {
    transform: none;
  }

  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar[data-abey-open="true"] {
    box-shadow: 24px 0 72px rgba(15, 23, 42, 0.22);
  }

  .abey.abey--dark .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar[data-abey-open="true"] {
    box-shadow: 28px 0 80px rgba(0, 0, 0, 0.55);
  }
}

@media (prefers-reduced-motion: reduce) {

  .abey-shell[data-abey-nav-mode="overlay"] .abey-shell__body>.abey-sidebar,
  .abey-shell[data-abey-nav-mode="drawer"] .abey-shell__body>.abey-sidebar,
  .abey-shell[data-abey-nav-mode="reveal"] .abey-shell__body>.abey-sidebar {
    transition-duration: 0.01ms !important;
  }
}

@media (max-width: 900px) {

  /* Mismo ancho que `.abey-sidebar` en este breakpoint (marca del app bar). */
  .abey-appbar--dashboard .abey-appbar__mark {
    flex: 0 0 min(18rem, 100vw);
    width: min(18rem, 100vw);
    max-width: min(18rem, 100vw);
  }

  .abey-sidebar {
    position: fixed;
    inset: var(--abey-appbar-h) 0 0 0;
    z-index: 8;
    width: min(18rem, 100vw);
    max-width: 18rem;
    box-shadow: var(--abey-shadow-lg);
    transform: translateX(-100%);
    transition: transform 0.2s ease, visibility 0.2s;
    visibility: hidden;
  }

  .abey-sidebar[data-abey-open="true"] {
    transform: translateX(0);
    visibility: visible;
  }

  .abey-sidebar__toggle {
    display: inline-flex;
  }

  .abey-sidebar__inner {
    padding-bottom: 2.5rem;
  }

  .abey-outlet {
    width: 100%;
  }
}

/* --- Tabla de l├¡neas de documento (`mountLineItemsTable` en @abeyjs/uikit, default block `abey-line-items`) --- */
.abey-line-items__wrap {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.abey-line-items__table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.88rem;
}

.abey-line-items__table th,
.abey-line-items__table td {
  padding: 0.35rem 0.5rem;
  text-align: left;
  border-bottom: 1px solid color-mix(in srgb, var(--abey-text) 8%, transparent);
  vertical-align: top;
}

.abey-line-items__table th {
  font-weight: 600;
  background: color-mix(in srgb, var(--abey-surface) 88%, var(--abey-text) 6%);
  white-space: nowrap;
}

.abey-line-items__input,
.abey-line-items__textarea {
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
  font: inherit;
  padding: 0.25rem 0.4rem;
  border-radius: var(--abey-radius-sm, 6px);
  border: 1px solid var(--abey-border);
  background: var(--abey-surface);
  color: var(--abey-text);
}

.abey-line-items__input[aria-invalid="true"],
.abey-line-items__textarea[aria-invalid="true"] {
  border-color: color-mix(in srgb, var(--abey-error) 55%, var(--abey-border));
  box-shadow: 0 0 0 2px color-mix(in srgb, var(--abey-error) 18%, transparent);
}

.abey-line-items__textarea {
  resize: vertical;
  min-height: 2.5rem;
}

.abey-line-items__input[type="number"] {
  text-align: right;
  font-variant-numeric: tabular-nums;
}

.abey-line-items__del {
  border: none;
  background: color-mix(in srgb, var(--abey-error) 14%, transparent);
  color: var(--abey-text);
  width: 1.75rem;
  height: 1.75rem;
  border-radius: var(--abey-radius-sm, 6px);
  cursor: pointer;
  font-size: 1.1rem;
  line-height: 1;
}

.abey-line-items__del:hover {
  background: color-mix(in srgb, var(--abey-error) 24%, transparent);
}

.abey-line-items__add {
  align-self: flex-start;
  padding: 0.4rem 0.75rem;
  font: inherit;
  font-size: 0.88rem;
  border-radius: var(--abey-radius-sm, 6px);
  border: 1px solid color-mix(in srgb, var(--abey-accent) 45%, transparent);
  background: color-mix(in srgb, var(--abey-accent) 8%, transparent);
  color: var(--abey-text);
  cursor: pointer;
}

.abey-line-items__add:hover {
  background: color-mix(in srgb, var(--abey-accent) 16%, transparent);
}
